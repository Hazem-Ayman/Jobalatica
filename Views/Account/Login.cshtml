@model Jobalatica.Models.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Sign In";
}

<style>
    .auth-container { 
        min-height: 80vh; 
        display: flex; 
        align-items: center; 
        justify-content: center; 
        padding: 40px 20px;
    }
    .auth-card { 
        background: var(--parchment); 
        border: var(--border); 
        box-shadow: var(--shadow); 
        width: 100%; 
        max-width: 440px; 
        padding: 48px; 
    }
    .auth-title { 
        font-family: var(--serif); 
        font-size: 42px; 
        font-weight: 900; 
        letter-spacing: -0.03em; 
        margin-bottom: 8px; 
        color: var(--ink); 
        text-align: center;
    }
    .auth-sub { 
        font-size: 14px; 
        color: rgba(26,22,18,0.5); 
        text-align: center; 
        margin-bottom: 40px; 
    }
    .form-group { margin-bottom: 24px; }
    .form-label { 
        display: block; 
        font-size: 11px; 
        font-weight: 700; 
        letter-spacing: 0.12em; 
        text-transform: uppercase; 
        color: var(--ink); 
        margin-bottom: 8px; 
    }
    .form-input { 
        width: 100%; 
        padding: 12px 16px; 
        font-family: var(--sans); 
        font-size: 14px; 
        background: var(--parchment); 
        border: var(--border); 
        outline: none; 
        color: var(--ink); 
    }
    .form-input:focus { background: white; }
    
    .btn-auth { 
        width: 100%; 
        padding: 14px; 
        background: var(--pink); 
        border: var(--border); 
        font-family: var(--sans); 
        font-size: 13px; 
        font-weight: 700; 
        letter-spacing: 0.1em; 
        text-transform: uppercase; 
        cursor: pointer; 
        box-shadow: var(--shadow-sm); 
        transition: all 0.1s; 
        margin-top: 12px;
    }
    .btn-auth:hover { transform: translate(-2px, -2px); box-shadow: 6px 6px 0 var(--ink); }

    .auth-link { font-size: 13px; color: rgba(26,22,18,0.5); text-align: center; margin-top: 24px; }
    .auth-link a { color: var(--ink); font-weight: 700; text-decoration: underline; }
    
    .checkbox-group { display: flex; align-items: center; gap: 10px; margin-bottom: 24px; }
    .checkbox-input { width: 18px; height: 18px; border: var(--border); appearance: none; background: var(--parchment); cursor: pointer; position: relative; }
    .checkbox-input:checked { background: var(--pink); }
    .checkbox-input:checked::after { content: ''; position: absolute; top: 2px; left: 6px; width: 4px; height: 8px; border: solid var(--ink); border-width: 0 2px 2px 0; transform: rotate(45deg); }
</style>

<div class="auth-container">
    <div class="auth-card">
        <h1 class="auth-title">Welcome <em>Back</em></h1>
        <p class="auth-sub">Enter the matrix to access market data.</p>

        <form asp-action="Login" method="post">
            <div asp-validation-summary="ModelOnly" style="color: var(--pink); font-size: 12px; margin-bottom: 20px; font-weight: 700;"></div>

            <div class="form-group">
                <label asp-for="Email" class="form-label">Email Address</label>
                <input asp-for="Email" class="form-input" placeholder="name@company.com">
                <span asp-validation-for="Email" style="color: var(--pink); font-size: 11px;"></span>
            </div>

            <div class="form-group">
                <div style="display: flex; justify-content: space-between;">
                    <label asp-for="Password" class="form-label">Password</label>
                    <a href="#" style="font-size: 11px; color: rgba(26,22,18,0.4); text-transform: uppercase; font-weight: 700; letter-spacing: 0.05em;">Forgot?</a>
                </div>
                <input asp-for="Password" class="form-input" type="password">
                <span asp-validation-for="Password" style="color: var(--pink); font-size: 11px;"></span>
            </div>

            <div class="checkbox-group">
                <input asp-for="RememberMe" type="checkbox" class="checkbox-input">
                <label asp-for="RememberMe" style="font-size: 13px; font-weight: 500; color: rgba(26,22,18,0.6); cursor: pointer;">Remember this session</label>
            </div>

            <button type="submit" class="btn-auth">Sign In →</button>

            <p class="auth-link">
                New here? <a asp-action="Register">Create an account</a>
            </p>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
