@model Jobalatica.Models.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "Create Account";
}

<style>
    .auth-container { 
        min-height: 80vh; 
        display: flex; 
        align-items: center; 
        justify-content: center; 
        padding: 40px 20px;
    }
    .auth-card { 
        background: var(--parchment); 
        border: var(--border); 
        box-shadow: var(--shadow); 
        width: 100%; 
        max-width: 800px; 
        padding: 64px; 
    }
    .auth-title { 
        font-family: var(--serif); 
        font-size: 56px; 
        font-weight: 900; 
        letter-spacing: -0.03em; 
        margin-bottom: 8px; 
        color: var(--ink); 
        text-align: center;
    }
    .auth-sub { 
        font-size: 16px; 
        color: rgba(26,22,18,0.5); 
        text-align: center; 
        margin-bottom: 56px; 
    }
    .form-section-title {
        font-family: var(--serif);
        font-size: 24px;
        font-weight: 800;
        margin: 48px 0 24px;
        display: flex;
        align-items: center;
        gap: 12px;
        color: var(--ink);
    }
    .form-section-num {
        font-family: var(--sans);
        font-size: 12px;
        width: 24px;
        height: 24px;
        background: var(--ink);
        color: var(--parchment);
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .role-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; }
    .role-card { 
        border: var(--border); 
        padding: 24px; 
        cursor: pointer; 
        background: var(--parchment); 
        transition: all 0.15s;
        position: relative;
    }
    .role-card:hover { transform: translate(-2px, -2px); box-shadow: var(--shadow-sm); }
    .role-card.active { background: white; box-shadow: 6px 6px 0 var(--ink); border-color: var(--ink); }
    .role-card input { position: absolute; opacity: 0; }
    .role-card-title { font-weight: 800; font-size: 16px; margin-bottom: 4px; display: block; }
    .role-card-desc { font-size: 12px; color: rgba(26,22,18,0.5); line-height: 1.4; }

    .pill-grid { display: flex; flex-wrap: wrap; gap: 12px; }
    .pill-item { 
        padding: 8px 18px; 
        border: var(--border); 
        font-size: 13px; 
        font-weight: 700; 
        cursor: pointer; 
        background: var(--parchment); 
        transition: all 0.1s;
    }
    .pill-item:hover { background: var(--parchment-2); }
    .pill-item.active { background: var(--lavender); box-shadow: 3px 3px 0 var(--ink); transform: translate(-1px, -1px); }
    .pill-item input { display: none; }

    .strength-meter { 
        height: 4px; 
        width: 100%; 
        background: var(--parchment-2); 
        border: 1px solid var(--ink); 
        margin-top: 8px; 
        position: relative;
    }
    .strength-fill { height: 100%; background: var(--ink); width: 0%; transition: all 0.3s; }

    .form-group { margin-bottom: 20px; }
    .form-label { 
        display: block; 
        font-size: 11px; 
        font-weight: 700; 
        letter-spacing: 0.12em; 
        text-transform: uppercase; 
        color: var(--ink); 
        margin-bottom: 8px; 
    }
    .form-input { 
        width: 100%; 
        max-width: 400px;
        padding: 12px 16px; 
        font-family: var(--sans); 
        font-size: 14px; 
        background: var(--parchment); 
        border: var(--border); 
        outline: none; 
        color: var(--ink); 
    }
    .form-input:focus { background: white; }
    
    .btn-auth { 
        padding: 14px 28px; 
        background: var(--pink); 
        border: var(--border); 
        font-family: var(--sans); 
        font-size: 13px; 
        font-weight: 700; 
        letter-spacing: 0.1em; 
        text-transform: uppercase; 
        cursor: pointer; 
        box-shadow: var(--shadow-sm); 
        transition: all 0.1s; 
    }
    .btn-auth:hover { transform: translate(-2px, -2px); box-shadow: 6px 6px 0 var(--ink); }

    .auth-link { font-size: 13px; color: rgba(26,22,18,0.5); }
    .auth-link a { color: var(--ink); font-weight: 700; text-decoration: underline; }
</style>

<div class="auth-container">
    <div class="auth-card">
        <h1 class="auth-title">Join the <em>Collective</em></h1>
        <p class="auth-sub">Initialize your profile and track market velocity.</p>

        <form asp-action="Register" method="post">
            <div asp-validation-summary="ModelOnly" style="color: var(--pink); font-size: 12px; margin-bottom: 20px; font-weight: 700;"></div>

            <div class="form-section-title"><span class="form-section-num">1</span> Core Identity</div>
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 24px;">
                <div class="form-group">
                    <label asp-for="DisplayName" class="form-label">Display Name</label>
                    <input asp-for="DisplayName" class="form-input" placeholder="John Doe">
                    <span asp-validation-for="DisplayName" style="color: var(--pink); font-size: 11px;"></span>
                </div>

                <div class="form-group">
                    <label asp-for="JobTitle" class="form-label">Job Title</label>
                    <input asp-for="JobTitle" class="form-input" placeholder="Fullstack Developer">
                    <span asp-validation-for="JobTitle" style="color: var(--pink); font-size: 11px;"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Email" class="form-label">Email Address</label>
                    <input asp-for="Email" class="form-input" placeholder="name@company.com">
                    <span asp-validation-for="Email" style="color: var(--pink); font-size: 11px;"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Password" class="form-label">Password</label>
                    <input asp-for="Password" id="password" type="password" class="form-input">
                    <div class="strength-meter">
                        <div id="password-strength" class="strength-fill"></div>
                    </div>
                    <span asp-validation-for="Password" style="color: var(--pink); font-size: 11px;"></span>
                </div>

                <div class="form-group">
                    <label asp-for="ConfirmPassword" class="form-label">Confirm Password</label>
                    <input asp-for="ConfirmPassword" type="password" class="form-input">
                    <span asp-validation-for="ConfirmPassword" style="color: var(--pink); font-size: 11px;"></span>
                </div>
            </div>

            <div class="form-section-title"><span class="form-section-num">2</span> Technical Signal</div>
            <p style="font-size: 11px; font-weight: 700; text-transform: uppercase; color: rgba(26,22,18,0.4); margin-bottom: 16px; letter-spacing: 0.1em;">Select Tech Stack</p>
            <div class="pill-grid">
                @foreach (var skill in Model.AllSkills)
                {
                    <label class="pill-item">
                        <input type="checkbox" name="TechInterests" value="@skill.Name">
                        @skill.Name
                    </label>
                }
            </div>

            <div style="margin-top: 64px; border-top: var(--border); padding-top: 32px; display: flex; align-items: center; justify-content: space-between;">
                <p class="auth-link" style="margin: 0; text-align: left;">
                    Already registered? <a asp-action="Login">Sign in</a>
                </p>
                <button type="submit" class="btn-auth" style="width: 240px; margin: 0;">Initialize Access →</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Password Strength
        const passwordInput = document.getElementById('password');
        const strengthBar = document.getElementById('password-strength');

        passwordInput.addEventListener('input', () => {
            const val = passwordInput.value;
            let strength = 0;
            if (val.length > 0) strength += 25;
            if (val.length > 8) strength += 25;
            if (/[A-Z]/.test(val)) strength += 25;
            if (/[0-9]/.test(val) || /[^A-Za-z0-9]/.test(val)) strength += 25;

            strengthBar.style.width = strength + '%';
            if (strength <= 25) strengthBar.style.background = '#F2708A';
            else if (strength <= 50) strengthBar.style.background = '#F5C4A8';
            else if (strength <= 75) strengthBar.style.background = '#C8C3E8';
            else strengthBar.style.background = '#4ADE80';
        });

        // Pill Item Selection
        document.querySelectorAll('.pill-item').forEach(pill => {
            const input = pill.querySelector('input');
            pill.addEventListener('click', () => {
                setTimeout(() => {
                    if (input.checked) pill.classList.add('active');
                    else pill.classList.remove('active');
                }, 10);
            });
        });
    </script>
}
