@model Jobalatica.Models.ViewModels.ProfileViewModel
@{
    ViewData["Title"] = "My Profile";
}

<div class="flex flex-col lg:flex-row gap-8">
    <!-- Left Sidebar: Profile Summary -->
    <aside class="w-full lg:w-72 flex-shrink-0">
        <div class="bg-white dark:bg-gray-800 p-8 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-700 text-center sticky top-4">
            <div class="relative w-32 h-32 mx-auto mb-4">
                <div class="w-full h-full rounded-full bg-blue-500 flex items-center justify-center text-white text-4xl font-bold">
                    @(string.IsNullOrEmpty(Model.DisplayName) ? "?" : Model.DisplayName.Substring(0, 1).ToUpper())
                </div>
            </div>
            <h2 class="text-xl font-bold mb-1">@Model.DisplayName</h2>
            <p class="text-sm text-gray-500 mb-6">@User.Identity?.Name</p>
            
            <div class="grid grid-cols-2 gap-2 mb-8">
                <div class="p-3 bg-gray-50 dark:bg-gray-700 rounded-xl">
                    <span class="block text-lg font-bold">@Model.SavedJobs.Count</span>
                    <span class="text-[10px] text-gray-400 uppercase font-bold">Saved</span>
                </div>
                <div class="p-3 bg-gray-50 dark:bg-gray-700 rounded-xl">
                    <span class="block text-lg font-bold">@Model.UserSkillIds.Count</span>
                    <span class="text-[10px] text-gray-400 uppercase font-bold">Skills</span>
                </div>
            </div>

            <nav class="space-y-2">
                <a href="/Profile" class="flex items-center p-3 text-sm font-bold bg-blue-50 text-blue-700 rounded-xl dark:bg-blue-900 dark:text-blue-200">
                    <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
                    Settings
                </a>
                <a href="/Profile/SavedJobs" class="flex items-center p-3 text-sm font-bold text-gray-600 hover:bg-gray-50 rounded-xl dark:text-gray-400 dark:hover:bg-gray-700">
                    <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path></svg>
                    Saved Jobs
                </a>
            </nav>
        </div>
    </aside>

    <!-- Right Content: Form -->
    <div class="flex-grow">
        @if (TempData["Success"] != null)
        {
            <div class="p-4 mb-4 text-sm text-green-800 rounded-lg bg-green-50 dark:bg-gray-800 dark:text-green-400 font-bold" role="alert">
                @TempData["Success"]
            </div>
        }

        <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-700 p-8">
            <h2 class="text-2xl font-bold mb-8">Account Settings</h2>
            
            <form asp-action="SaveProfile" method="post" enctype="multipart/form-data" class="space-y-8">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                    <div>
                        <label asp-for="DisplayName" class="block mb-2 text-sm font-bold text-gray-500 uppercase tracking-wider">Display Name</label>
                        <input asp-for="DisplayName" class="w-full bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-xl focus:ring-blue-500 focus:border-blue-500 p-3 dark:bg-gray-700 dark:border-gray-600 dark:text-white">
                    </div>

                    <div>
                        <label asp-for="ExperienceLevel" class="block mb-2 text-sm font-bold text-gray-500 uppercase tracking-wider">Experience Level</label>
                        <select asp-for="ExperienceLevel" class="w-full bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-xl focus:ring-blue-500 focus:border-blue-500 p-3 dark:bg-gray-700 dark:border-gray-600 dark:text-white">
                            <option value="Entry">Entry Level</option>
                            <option value="Mid">Mid Level</option>
                            <option value="Senior">Senior Level</option>
                            <option value="Lead">Lead / Architect</option>
                        </select>
                    </div>
                </div>

                <div>
                    <label class="block mb-4 text-sm font-bold text-gray-500 uppercase tracking-wider">Skills Selection</label>
                    <div class="flex flex-wrap gap-2" id="skill-pills">
                        @foreach (var skill in Model.AllSkills)
                        {
                            bool isSelected = Model.UserSkillIds.Contains(skill.Id);
                            <div class="skill-pill cursor-pointer px-4 py-2 rounded-xl border-2 transition-all font-bold text-sm @(isSelected ? "bg-blue-600 border-blue-600 text-white" : "border-gray-200 text-gray-600 hover:border-blue-300")"
                                 data-skill-id="@skill.Id">
                                @skill.Name
                                <input type="checkbox" name="UserSkillIds" value="@skill.Id" class="hidden" @(isSelected ? "checked" : "")>
                            </div>
                        }
                    </div>
                </div>

                <div class="pt-8 border-t border-gray-100 dark:border-gray-700">
                    <button type="submit" class="text-white bg-blue-700 hover:bg-blue-800 focus:ring-4 focus:outline-none focus:ring-blue-300 font-bold rounded-xl text-sm px-12 py-4 text-center dark:bg-blue-600 dark:hover:bg-blue-700 dark:focus:ring-blue-800">
                        Save Profile Changes
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.skill-pill').forEach(pill => {
            pill.addEventListener('click', () => {
                const checkbox = pill.querySelector('input');
                checkbox.checked = !checkbox.checked;
                
                if (checkbox.checked) {
                    pill.classList.remove('border-gray-200', 'text-gray-600', 'hover:border-blue-300');
                    pill.classList.add('bg-blue-600', 'border-blue-600', 'text-white');
                } else {
                    pill.classList.add('border-gray-200', 'text-gray-600', 'hover:border-blue-300');
                    pill.classList.remove('bg-blue-600', 'border-blue-600', 'text-white');
                }
            });
        });
    </script>
}
