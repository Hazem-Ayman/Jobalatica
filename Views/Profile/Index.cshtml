@model Jobalatica.Models.ViewModels.ProfileViewModel
@{
    ViewData["Title"] = "My Profile";
}

<style>
    .profile-layout { display: grid; grid-template-columns: 300px 1fr; min-height: 80vh; border-bottom: var(--border); }
    .profile-sidebar { border-right: var(--border); }
    .identity-node { padding: 48px 32px; border-bottom: var(--border); text-align: center; }
    .identity-circle { width: 80px; height: 80px; background: var(--ink); border-radius: 50%; display: grid; place-items: center; font-family: var(--serif); font-size: 32px; font-weight: 900; color: var(--parchment); margin: 0 auto 16px; }
    .identity-name { font-family: var(--serif); font-size: 22px; font-weight: 700; letter-spacing: -0.02em; margin-bottom: 4px; }
    .identity-email { font-size: 12px; color: rgba(26,22,18,0.45); }
    
    .quick-stats { border-bottom: var(--border); display: grid; grid-template-columns: 1fr 1fr; }
    .qs-cell { padding: 24px 20px; border-right: var(--border); text-align: center; }
    .qs-cell:last-child { border-right: none; }
    .qs-num { font-family: var(--serif); font-size: 36px; font-weight: 900; letter-spacing: -0.04em; display: block; }
    .qs-label { font-size: 9px; font-weight: 600; letter-spacing: 0.15em; text-transform: uppercase; color: rgba(26,22,18,0.4); display: block; margin-top: 4px; }
    
    .local-nav { padding: 16px 0; }
    .local-nav a { display: flex; align-items: center; gap: 10px; padding: 12px 32px; font-size: 13px; font-weight: 500; text-decoration: none; color: rgba(26,22,18,0.5); transition: background 0.12s; border-left: 3px solid transparent; }
    .local-nav a.active { color: var(--ink); font-weight: 700; border-left-color: var(--ink); background: var(--parchment-2); }

    .form-area { padding: 48px 56px; }
    .form-header { margin-bottom: 40px; border-bottom: var(--border); padding-bottom: 28px; }
    .form-header h2 { font-family: var(--serif); font-size: 40px; font-weight: 900; letter-spacing: -0.03em; margin-bottom: 8px; }
    
    .form-section { margin-bottom: 40px; }
    .form-section-title { font-size: 10px; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(26,22,18,0.4); margin-bottom: 20px; display: flex; align-items: center; gap: 8px; }
    
    .field-grid { display: flex; gap: 32px; margin-bottom: 20px; align-items: flex-start; }
    .field { display: flex; flex-direction: column; gap: 8px; }
    .field label { font-size: 10px; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; color: rgba(26,22,18,0.5); }
    .field input, .field select { 
        width: 300px; 
        padding: 12px 16px;
        font-family: var(--sans);
        font-size: 14px;
        background: var(--parchment);
        border: var(--border);
        outline: none;
        color: var(--ink);
        appearance: none;
    }
    .field select {
        background-image: url("data:image/svg+xml,%3Csvg width='10' height='6' viewBox='0 0 10 6' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M0 0l5 6 5-6z' fill='%231A1612'/%3E%3C/svg%3E");
        background-repeat: no-repeat;
        background-position: right 16px center;
        padding-right: 40px;
    }

    .skill-matrix { display: flex; flex-wrap: wrap; gap: 8px; }
    .skill-pill { position: relative; }
    .skill-pill input[type="checkbox"] { position: absolute; opacity: 0; width: 0; height: 0; }
    .skill-pill label { display: block; padding: 8px 16px; border: var(--border); font-size: 11px; font-weight: 600; letter-spacing: 0.06em; cursor: pointer; background: var(--parchment); transition: background 0.12s; user-select: none; }
    .skill-pill input:checked + label { background: var(--ink); color: var(--parchment); }
</style>

<div class="profile-layout">
    <aside class="profile-sidebar">
        <div class="identity-node">
            <div class="identity-circle">
                <span>@(string.IsNullOrWhiteSpace(Model.DisplayName) ? "U" : Model.DisplayName[0].ToString().ToUpper())</span>
            </div>
            <div class="identity-name">@Model.DisplayName</div>
            @if (!string.IsNullOrEmpty(Model.JobTitle))
            {
                <div class="identity-job" style="font-family: var(--pixel); font-size: 16px; color: var(--pink); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 12px;">
                    @Model.JobTitle
                    @if (!string.IsNullOrEmpty(Model.CompanyName))
                    {
                        <span style="opacity: 0.8; font-size: 0.8em; margin-left: 4px; vertical-align: middle;">at @Model.CompanyName</span>
                    }
                </div>
            }
            <div class="identity-email">@User.Identity?.Name</div>
            <div style="margin-top: 24px;">
                <a asp-controller="Salary" asp-action="Submit" class="btn btn-dark" style="background: var(--ink); color: var(--parchment); font-size: 11px; padding: 10px 16px; width: 100%; border: var(--border);">Submit Salary Data →</a>
            </div>
        </div>
        <div class="quick-stats">
            <div class="qs-cell">
                <span class="qs-num">@Model.SavedJobs.Count</span>
                <span class="qs-label">Saved Jobs</span>
            </div>
            <div class="qs-cell">
                <span class="qs-num">@Model.UserSkillIds.Count</span>
                <span class="qs-label">Skills</span>
            </div>
        </div>
        <nav class="local-nav">
            <a asp-controller="Profile" asp-action="Index" class="active">Settings</a>
            <a asp-controller="Profile" asp-action="SavedJobs">Saved Signals</a>
        </nav>
    </aside>

    <div class="form-area">
        <div class="form-header">
            <h2>Account Settings</h2>
            <p>Manage your profile, job title, and tracked skills.</p>
        </div>

        <form asp-action="SaveProfile" method="post">
            @Html.AntiForgeryToken()
            <div class="form-section">
                <div class="form-section-title">
                    <div class="win-dot" style="background: var(--ink); width: 8px; height: 8px;"></div>
                    Personal Info
                </div>
                <div class="field-grid">
                    <div class="field">
                        <label asp-for="DisplayName">Display Name</label>
                        <input asp-for="DisplayName" type="text" />
                    </div>
                    <div class="field">
                        <label asp-for="JobTitle">Current Job Title</label>
                        <input asp-for="JobTitle" type="text" placeholder="e.g. Lead Systems Architect" />
                    </div>
                </div>
            </div>

            <div class="form-section">
                <div class="form-section-title">
                    <div class="win-dot" style="background: var(--ink); width: 8px; height: 8px;"></div>
                    Skill Matrix — Select Your Skills
                </div>
                <div class="skill-matrix">
                    @foreach (var skill in Model.AllSkills)
                    {
                        bool isSelected = Model.UserSkillIds.Contains(skill.Id);
                        <div class="skill-pill">
                            <input type="checkbox" name="UserSkillIds" value="@skill.Id" id="skill-@skill.Id" @(isSelected ? "checked" : "")>
                            <label for="skill-@skill.Id">@skill.Name</label>
                        </div>
                    }
                </div>
            </div>

            <div style="display: flex; align-items: center; gap: 16px; padding-top: 32px; border-top: 1px solid rgba(26,22,18,0.1);">
                <button type="submit" class="btn btn-dark" style="background: var(--ink); color: var(--parchment);">Save Profile Changes →</button>
                <span style="font-size: 11px; color: rgba(26,22,18,0.35);">Changes apply immediately across your saved searches.</span>
            </div>
        </form>
    </div>
</div>
