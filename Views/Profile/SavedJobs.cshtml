@model List<Jobalatica.Models.Entities.SavedJob>
@inject Jobalatica.Services.ISalaryEstimator SalaryEstimator
@{
    ViewData["Title"] = "Saved Signals";
}

<style>
    .profile-layout { display: grid; grid-template-columns: 300px 1fr; min-height: 80vh; border-bottom: var(--border); }
    .profile-sidebar { border-right: var(--border); }
    .identity-node { padding: 48px 32px; border-bottom: var(--border); text-align: center; }
    .identity-circle { width: 80px; height: 80px; background: var(--ink); border-radius: 50%; display: grid; place-items: center; font-family: var(--serif); font-size: 32px; font-weight: 900; color: var(--parchment); margin: 0 auto 16px; }
    
    .local-nav { padding: 16px 0; }
    .local-nav a { display: flex; align-items: center; gap: 10px; padding: 12px 32px; font-size: 13px; font-weight: 500; text-decoration: none; color: rgba(26,22,18,0.5); transition: background 0.12s; border-left: 3px solid transparent; }
    .local-nav a.active { color: var(--ink); font-weight: 700; border-left-color: var(--ink); background: var(--parchment-2); }

    .form-area { padding: 48px 56px; }
    .form-header { margin-bottom: 40px; border-bottom: var(--border); padding-bottom: 28px; }
    .form-header h2 { font-family: var(--serif); font-size: 40px; font-weight: 900; letter-spacing: -0.03em; margin-bottom: 8px; }

    .job-row { border-bottom: var(--border); padding: 24px 28px; transition: background 0.12s; border: var(--border); margin-bottom: 20px; box-shadow: var(--shadow-sm); }
</style>

<div class="profile-layout">
    <aside class="profile-sidebar">
        <div class="identity-node">
            <div class="identity-circle">@(string.IsNullOrEmpty(User.Identity?.Name) ? "?" : User.Identity.Name.Substring(0, 1).ToUpper())</div>
            <div class="identity-name">@User.Identity?.Name</div>
        </div>
        <nav class="local-nav">
            <a asp-controller="Profile" asp-action="Index">Settings</a>
            <a asp-controller="Profile" asp-action="SavedJobs" class="active">Saved Signals</a>
        </nav>
    </aside>

    <div class="form-area">
        <div class="form-header">
            <h2>Saved Jobs</h2>
            <p>@Model.Count roles you've bookmarked for later review.</p>
        </div>

        <div style="display: flex; flex-direction: column; gap: 0;">
            @if (!Model.Any())
            {
                <div style="padding: 100px 36px; text-align: center;">
                    <div style="font-family: var(--serif); font-size: 32px; font-weight: 900; color: rgba(26,22,18,0.2); margin-bottom: 12px;">Watchlist Empty</div>
                    <a asp-controller="Jobs" asp-action="Index" class="btn">Examine Marketplace →</a>
                </div>
            }
            else
            {
                @foreach (var saved in Model)
                {
                    <div class="job-row" id="saved-job-@saved.JobId">
                        <div style="display: flex; align-items: center; justify-content: space-between;">
                            <div>
                                <div style="font-family: var(--serif); font-size: 20px; font-weight: 700; letter-spacing: -0.02em; margin-bottom: 4px;">@saved.Job.Title</div>
                                <div style="font-size: 10px; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(26,22,18,0.35);">@saved.Job.Company · @saved.Job.Location</div>
                            </div>
                            <div style="display: flex; align-items: center; gap: 12px;">
                                @{
                                    var sEst = SalaryEstimator.GetEstimate(saved.Job);
                                }
                                @if (saved.Job.SalaryMin.HasValue)
                                {
                                    <div style="font-family: var(--serif); font-size: 18px; font-weight: 700;">$@((saved.Job.SalaryMin.Value / 1000).ToString("N0"))K–@((saved.Job.SalaryMax / 1000)?.ToString("N0"))K</div>
                                }
                                else if (sEst != null)
                                {
                                    <div style="font-family: var(--serif); font-size: 18px; font-weight: 700; opacity: 0.7;">
                                        $@((sEst.EstimatedSalaryMin / 1000).ToString("N0"))K–@((sEst.EstimatedSalaryMax / 1000).ToString("N0"))K
                                        <span style="font-size: 9px; font-weight: 700; color: var(--pink); margin-left: 4px;">AI</span>
                                    </div>
                                }
                                <form hx-post="/Jobs/Unsave?jobId=@saved.JobId" hx-target="#saved-job-@saved.JobId" hx-swap="delete">
                                    <button type="submit" class="btn btn-pink" style="padding: 8px 16px; font-size: 10px; box-shadow: var(--shadow-sm);">Unsave</button>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>
