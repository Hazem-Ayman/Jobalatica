@using System.Text.Json
@model Jobalatica.Models.ViewModels.HomeViewModel
@{
    ViewData["Title"] = "Know Your Worth";
}

<style>
    /* HERO */
    .hero { 
        border-bottom: var(--border); 
        display: flex; 
        flex-direction: column; 
        min-height: 80vh; 
    }

    .hero-left { 
        border-bottom: var(--border); 
        padding: 96px 56px; 
        display: flex; 
        flex-direction: column; 
        align-items: center; 
        text-align: center;
        position: relative;
        background: url('/Img/market.avif') center/cover no-repeat;
        background-attachment: fixed;
    }
    .hero-left::before {
        content: "";
        position: absolute;
        top: 0; left: 0; right: 0; bottom: 0;
        background: rgba(246, 241, 230, 0.45);
        z-index: 1;
    }
    .hero-left > * { position: relative; z-index: 2; }
    .hero-title { font-family: var(--serif); font-size: clamp(60px, 8vw, 120px); font-weight: 900; line-height: 0.95; letter-spacing: -0.04em; margin-bottom: 32px; color: var(--ink); }
    .hero-title em { font-style: italic; font-weight: 400; color: var(--ink-2); }
    .hero-sub { font-size: 1.25rem; font-weight: 300; line-height: 1.6; color: rgba(26,22,18,0.7); max-width: 600px; margin-top: 40px; }
    .hero-search { display: flex; gap: 0; border: var(--border); box-shadow: var(--shadow); width: 100%; max-width: 600px; }
    .hero-search input { flex: 1; padding: 20px 24px; font-family: var(--sans); font-size: 16px; background: var(--parchment); color: var(--ink); border: none; outline: none; }
    .hero-search button { padding: 20px 32px; background: var(--ink); color: var(--parchment); border: none; border-left: var(--border); font-family: var(--sans); font-size: 12px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; cursor: pointer; white-space: nowrap; }

    .hero-right { display: flex; align-items: center; justify-content: center; padding: 80px 56px; position: relative; overflow: hidden; }
    .hero-window { border: var(--border); box-shadow: var(--shadow); background: var(--parchment); width: 100%; max-width: 500px; }
    .hero-window-bar { border-bottom: var(--border); padding: 12px 20px; display: flex; align-items: center; gap: 12px; font-family: var(--sans); font-size: 11px; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; }
    .stat-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0; }
    .stat-cell { padding: 40px 32px; border-right: var(--border); border-bottom: var(--border); text-align: center; }
    .stat-cell:nth-child(2n) { border-right: none; }
    .stat-cell:nth-child(n+3) { border-bottom: none; }
    .stat-num { font-family: var(--serif); font-size: 52px; font-weight: 900; line-height: 1; letter-spacing: -0.04em; color: var(--ink); display: block; }
    .stat-label { font-family: var(--pixel); font-size: 11px; font-weight: 400; letter-spacing: 0.05em; text-transform: uppercase; color: rgba(26,22,18,0.5); margin-top: 10px; display: block; }

    /* EDITORIAL */
    .editorial { display: flex; flex-direction: column; border-bottom: var(--border); }
    .editorial-text { 
        padding: 96px 56px; 
        border-right: none; 
        border-bottom: var(--border); 
        display: flex; 
        flex-direction: column; 
        align-items: center; 
        text-align: center;
    }
    .editorial-visual { 
        display: flex; 
        align-items: center; 
        justify-content: center; 
        padding: 80px 56px; 
    }
    .editorial-visual::before {
        content: "";
        position: absolute;
        top: 0; left: 0; right: 0; bottom: 0;
        background: rgba(246, 241, 230, 0.10);
        z-index: 1;
    }
    .editorial-visual > * { position: relative; z-index: 2; }
    .editorial-title { font-family: var(--serif); font-size: clamp(48px, 6vw, 96px); font-weight: 900; line-height: 0.95; letter-spacing: -0.04em; margin-bottom: 32px; color: var(--ink); }
    .editorial-body { font-size: 1.1rem; font-weight: 300; line-height: 1.7; color: rgba(26,22,18,0.6); margin-bottom: 48px; max-width: 700px; }

    /* MARKET FEED */
    .section-header { border-bottom: var(--border); padding: 48px 56px; display: flex; align-items: center; justify-content: space-between; }
    .section-title { font-family: var(--serif); font-size: 56px; font-weight: 900; letter-spacing: -0.04em; color: var(--ink); }
    .jobs-grid { display: flex; flex-direction: column; border-bottom: var(--border); }

    .win-label { display: flex; align-items: center; gap: 8px; font-family: var(--pixel); font-size: 13px; font-weight: 400; letter-spacing: 0.05em; text-transform: uppercase; color: var(--ink); margin-bottom: 24px; }
    .win-dot { width: 12px; height: 12px; flex-shrink: 0; background: var(--ink); }

    .chart-window { border: var(--border); box-shadow: var(--shadow); background: var(--parchment); width: 100%; max-width: 1000px; }
    .chart-window-bar { border-bottom: var(--border); padding: 12px 20px; display: flex; align-items: center; gap: 12px; font-family: var(--pixel); font-size: 11px; font-weight: 400; letter-spacing: 0.05em; text-transform: uppercase; }

    /* TYPEWRITER CURSOR */
    .typewriter-cursor { font-style: normal; color: var(--ink); font-weight: 400; animation: blink 1s infinite; margin-left: 2px; }
    @@keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0; } }
</style>

<!-- HERO -->
<section class="hero">
    <div class="hero-left">
        <div class="win-label">
            <div class="win-dot" style="background: var(--pink);"></div>
            MARKET INTELLIGENCE
        </div>
        <h1 class="hero-title">
            Know your worth<br>
            <em id="typewriter">in real-time.</em><span class="typewriter-cursor">|</span>
        </h1>
        
        <form asp-controller="Jobs" asp-action="Index" method="get" class="hero-search">
            <input type="text" name="query" placeholder="Analyze a role or technology..."/>
            <button type="submit">Analyze →</button>
        </form>

        <p class="hero-sub">
            Analyze signals on demand across roles, skills, and market value.
        </p>
    </div>
    <div class="hero-right">
        <div class="hero-window">
            <div class="hero-window-bar">
                <div class="win-dot" style="background: var(--green);"></div>
                MARKET PULSE — LIVE SIGNALS
                <span style="margin-left:auto;font-size:10px;color:rgba(26,22,18,0.45);letter-spacing:0.05em;">Last updated: @DateTime.Now.ToString("MM.dd.yy")</span>
            </div>
            <div class="stat-grid">
                <div class="stat-cell">
                    <span class="stat-num" id="c1">0</span>
                    <span class="stat-label">Active Signals</span>
                </div>
                <div class="stat-cell">
                    <span class="stat-num" id="c2">0</span>
                    <span class="stat-label">Roles Tracked</span>
                </div>
                <div class="stat-cell">
                    <span class="stat-num" id="c3">0</span>
                    <span class="stat-label">Markets</span>
                </div>
                <div class="stat-cell">
                    <span class="stat-num" id="c4">0</span>
                    <span class="stat-label">Companies</span>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- EDITORIAL -->
<section class="editorial">
    <div class="editorial-text">
        <div class="win-label">
            <div class="win-dot"></div>
            COLLECTIVE INTELLIGENCE
        </div>
        <h2 class="editorial-title">
            A living matrix<br>of professional <em>worth.</em>
        </h2>
        <p class="editorial-body">
            Every signal is verified, aggregated, and returned to the collective. JobPulse isn't just a search engine — it's real-time market infrastructure.
        </p>
        <a asp-controller="Rankings" asp-action="Index" class="btn">Explore Rankings →</a>
    </div>
    <div class="editorial-visual">
        <div style="width: 100%; max-width: 1000px;">
            <div class="win-label">
                <div class="win-dot"></div>
                POSTINGS VOLUME — TOP ROLES
            </div>
            <div style="height: 450px;">
                <canvas id="trendingRolesChart"></canvas>
            </div>
        </div>
    </div>
</section>

<!-- MARKET FEED -->
<section>
    <div class="section-header">
        <h2 class="section-title">Market Feed</h2>
        <a asp-controller="Jobs" asp-action="Index" class="btn">Explore Full Market →</a>
    </div>
    <div class="jobs-grid">
        @foreach (var job in Model.RecentJobs.Take(5))
        {
            <div style="border-bottom: var(--border); padding: 48px 56px; transition: background 0.15s;" onmouseenter="this.style.background='var(--parchment-2)'" onmouseleave="this.style.background=''">
                <div style="max-width: 1000px; margin: 0 auto;">
                    @await Html.PartialAsync("_JobCard", job, new ViewDataDictionary(ViewData) { { "IsSaved", Model.SavedJobIds.Contains(job.Id) } })
                </div>
            </div>
        }
    </div>
</section>

@section Scripts {
    <script>
        // Typewriter Effect
        const typeTarget = document.getElementById('typewriter');
        const phrases = ["in real-time.", "like a collaborator.", "like a co-founder.", "with confidence."];
        let phraseIdx = 0;
        let charIdx = 0;
        let isDeleting = false;
        let typeSpeed = 100;

        function type() {
            const currentPhrase = phrases[phraseIdx];
            
            if (isDeleting) {
                typeTarget.textContent = currentPhrase.substring(0, charIdx - 1);
                charIdx--;
                typeSpeed = 50;
            } else {
                typeTarget.textContent = currentPhrase.substring(0, charIdx + 1);
                charIdx++;
                typeSpeed = 150;
            }

            if (!isDeleting && charIdx === currentPhrase.length) {
                isDeleting = true;
                typeSpeed = 2000; // Pause at end
            } else if (isDeleting && charIdx === 0) {
                isDeleting = false;
                phraseIdx = (phraseIdx + 1) % phrases.length;
                typeSpeed = 500;
            }

            setTimeout(type, typeSpeed);
        }

        // Trending Roles Chart
        const labels = @Html.Raw(JsonSerializer.Serialize(Model.TopRoles.Select(r => r.Title)));
        const data = @Html.Raw(JsonSerializer.Serialize(Model.TopRoles.Select(r => r.Count)));

        new Chart(document.getElementById('trendingRolesChart'), {
            // ... (keep existing chart config)
            type: 'bar',
            data: {
                labels: labels,
                datasets: [{
                    data: data,
                    backgroundColor: '#1A1612',
                    hoverBackgroundColor: '#F2708A',
                    borderWidth: 0,
                    borderRadius: 0
                }]
            },
            options: {
                indexAxis: 'y',
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    x: { display: false, beginAtZero: true },
                    y: {
                        grid: { display: false },
                        ticks: { 
                            color: 'rgba(26,22,18,0.5)', 
                            font: { family: 'DM Sans', size: 11, weight: 'bold' }
                        }
                    }
                }
            }
        });

        // Animated counters
        function animateCount(el, target, duration = 1500) {
            let start = null;
            function step(ts) {
                if (!start) start = ts;
                const prog = Math.min((ts - start) / duration, 1);
                const ease = 1 - Math.pow(1 - prog, 3);
                el.textContent = Math.round(ease * target).toLocaleString();
                if (prog < 1) requestAnimationFrame(step);
            }
            requestAnimationFrame(step);
        }

        document.addEventListener('DOMContentLoaded', () => {
            type(); // Start typewriter
            animateCount(document.getElementById('c1'), 12400);
            animateCount(document.getElementById('c2'), 850);
            animateCount(document.getElementById('c3'), 52);
            animateCount(document.getElementById('c4'), 1200);
        });
    </script>
}
