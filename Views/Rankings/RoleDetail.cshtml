@using System.Text.Json
@model Jobalatica.Models.ViewModels.RoleDetailViewModel
@{
    ViewData["Title"] = $"{Model.JobTitle} Market Analysis";
}

<style>
    .detail-container { max-width: 1200px; margin: 0 auto; padding: 48px 56px; }
    .breadcrumb { display: flex; align-items: center; gap: 8px; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.15em; color: rgba(26,22,18,0.4); margin-bottom: 24px; }
    .breadcrumb a { color: inherit; text-decoration: none; }
    .breadcrumb a:hover { color: var(--ink); }
    
    .page-title { font-family: var(--serif); font-size: clamp(40px, 5vw, 64px); font-weight: 900; letter-spacing: -0.03em; margin-bottom: 48px; color: var(--ink); }
    .page-title em { font-style: italic; font-weight: 400; }

    .card-brutal { 
        background: var(--parchment); 
        border: var(--border); 
        box-shadow: var(--shadow); 
        padding: 32px; 
        margin-bottom: 32px; 
        position: relative;
    }
    .card-dark { 
        background: var(--ink); 
        color: var(--parchment); 
        border: var(--border); 
        box-shadow: var(--shadow-sm); 
    }
    
    .stat-label { font-size: 10px; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(26,22,18,0.4); margin-bottom: 16px; display: block; }
    .card-dark .stat-label { color: rgba(237,232,223,0.4); }
    
    .stat-value { font-family: var(--serif); font-size: 40px; font-weight: 900; letter-spacing: -0.04em; }
    .stat-diff { font-size: 12px; font-weight: 700; color: var(--green); margin-left: 8px; }
    
    .section-title { font-family: var(--serif); font-size: 28px; font-weight: 900; margin-bottom: 32px; letter-spacing: -0.02em; }
    
    .salary-row { display: flex; justify-content: space-between; align-items: center; padding: 16px 20px; border: var(--border); margin-bottom: 12px; background: var(--parchment); transition: all 0.15s; }
    .salary-row.active { background: var(--ink); color: var(--parchment); transform: translate(-4px, -4px); box-shadow: 8px 8px 0 var(--pink); }
    .salary-row span:last-child { font-family: var(--serif); font-size: 18px; font-weight: 900; }

    .lock-overlay { 
        position: absolute; inset: 0; background: rgba(237,232,223,0.8); 
        backdrop-filter: blur(4px); display: flex; align-items: center; 
        justify-content: center; z-index: 10; text-align: center; padding: 40px;
    }

    .company-pill { display: flex; align-items: center; gap: 12px; padding: 12px 20px; border: var(--border); background: var(--parchment); font-weight: 700; font-size: 14px; }
    .company-icon { width: 32px; height: 32px; background: var(--ink); color: var(--parchment); display: grid; place-items: center; font-family: var(--serif); font-weight: 900; }
</style>

<div class="detail-container">
    <div class="breadcrumb">
        <a href="/Rankings">Rankings</a>
        <span>/</span>
        <span style="color: var(--ink);">@Model.JobTitle</span>
    </div>
    
    <h1 class="page-title">@Model.JobTitle <em>Intelligence</em></h1>

    <!-- Stat Grid -->
    <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px; margin-bottom: 64px;">
        <div class="card-brutal card-dark">
            <span class="stat-label">Total Openings</span>
            <div style="display: flex; align-items: baseline;">
                <span class="stat-value">@Model.SampleSize</span>
                <span class="stat-diff">+12%</span>
            </div>
        </div>
        <div class="card-brutal card-dark">
            <span class="stat-label">Market Avg Salary</span>
            <div style="display: flex; align-items: baseline;">
                <span class="stat-value">$@(((Model.AvgSalaryMin + Model.AvgSalaryMax) / 2).ToString("N0"))</span>
                <span style="font-size: 12px; margin-left: 8px; opacity: 0.5;">USD/YR</span>
            </div>
        </div>
        <div class="card-brutal card-dark">
            <span class="stat-label">Demand Score</span>
            <div style="display: flex; align-items: center; gap: 16px;">
                <span class="stat-value">88<small style="font-size: 0.5em; opacity: 0.4;">/100</small></span>
                <div style="flex: 1; height: 8px; background: rgba(237,232,223,0.1); border: 1px solid rgba(237,232,223,0.2);">
                    <div style="height: 100%; background: var(--pink); width: 88%;"></div>
                </div>
            </div>
        </div>
    </div>

    <div style="display: grid; grid-template-columns: 1fr 340px; gap: 48px; margin-bottom: 64px;">
        <!-- Charts Column -->
        <div>
            <div class="card-brutal" style="margin-bottom: 48px;">
                <h2 class="section-title">Hiring Velocity Trend</h2>
                <div style="height: 340px;">
                    @if (Model.Trend.Any())
                    {
                        <canvas id="demandTrendChart"></canvas>
                    }
                    else
                    {
                        <div style="height: 100%; display: grid; place-items: center; border: 2px dashed rgba(26,22,18,0.1); font-style: italic; color: rgba(26,22,18,0.3);">
                            Gathering historical signals...
                        </div>
                    }
                </div>
            </div>

            <h2 class="section-title">Sample Postings for @Model.JobTitle</h2>
            <div style="display: grid; grid-template-columns: 1fr; gap: 24px; margin-bottom: 32px;">
                @foreach (var job in Model.SampleJobs)
                {
                    <div style="border-bottom: var(--border); padding: 16px 0;">
                        @await Html.PartialAsync("_JobCard", job, new ViewDataDictionary(ViewData) { { "IsSaved", Model.SavedJobIds.Contains(job.Id) } })
                    </div>
                }
            </div>
            <a href="/Jobs?query=@Model.JobTitle" class="btn btn-dark" style="width: fit-content; padding: 16px 32px;">Explore All @Model.JobTitle Roles →</a>
        </div>

        <!-- Sidebar -->
        <div>
            <div class="card-brutal" style="padding: 24px;">
                <h2 style="font-family: var(--serif); font-size: 22px; font-weight: 900; margin-bottom: 24px;">Skill Priority</h2>
                <div style="height: 300px;">
                    <canvas id="roleSkillsChart"></canvas>
                </div>
            </div>

            <div class="card-brutal" style="padding: 32px; min-height: 400px;">
                <h2 style="font-family: var(--serif); font-size: 22px; font-weight: 900; margin-bottom: 24px;">Salary by Experience</h2>
                
                <div style="position: relative;">
                    <div class="salary-breakdown @(!Model.HasContributedSalary ? "blur-md" : "")">
                        <div class="salary-row"><span>Entry Level</span><span>$45K - $60K</span></div>
                        <div class="salary-row active"><span>Mid Level</span><span>$70K - $95K</span></div>
                        <div class="salary-row"><span>Senior Level</span><span>$110K - $150K</span></div>
                        <div class="salary-row"><span>Lead / Arch</span><span>$160K+</span></div>
                    </div>

                    @if (!Model.HasContributedSalary)
                    {
                        <div class="lock-overlay">
                            <div>
                                <div style="width: 48px; height: 48px; background: var(--pink); border: var(--border); display: grid; place-items: center; margin: 0 auto 16px;">
                                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--ink)" stroke-width="2.5"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
                                </div>
                                <h3 style="font-family: var(--serif); font-size: 20px; font-weight: 900; margin-bottom: 8px;">Restricted Access</h3>
                                <p style="font-size: 12px; color: rgba(26,22,18,0.5); margin-bottom: 20px;">Contribute your salary data to unlock the full market matrix.</p>
                                <a href="/Salary/Submit" class="btn btn-dark" style="font-size: 11px; padding: 12px 20px;">Contribute Now</a>
                            </div>
                        </div>
                    }
                </div>
                <p style="font-size: 11px; color: rgba(26,22,18,0.4); margin-top: 24px; font-style: italic;">Based on @Model.SampleSize verified signals.</p>
            </div>
        </div>
    </div>

    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 48px;">
        <div class="card-brutal">
            <h2 class="section-title">Salary by Location</h2>
            <div style="position: relative;">
                <div class="@(!Model.HasContributedSalary ? "blur-md" : "")">
                    <table style="width: 100%; border-collapse: collapse;">
                        <thead>
                            <tr style="text-align: left; font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.15em; color: rgba(26,22,18,0.4); border-bottom: var(--border);">
                                <th style="padding: 12px 0;">City</th>
                                <th style="padding: 12px 0; text-align: right;">Avg. Salary</th>
                            </tr>
                        </thead>
                        <tbody style="font-family: var(--serif); font-size: 18px; font-weight: 700;">
                            <tr style="border-bottom: 1px solid rgba(26,22,18,0.05);"><td style="padding: 16px 0;">Dubai, UAE</td><td style="padding: 16px 0; text-align: right;">$95,400</td></tr>
                            <tr style="border-bottom: 1px solid rgba(26,22,18,0.05);"><td style="padding: 16px 0;">Riyadh, SA</td><td style="padding: 16px 0; text-align: right;">$82,000</td></tr>
                            <tr style="border-bottom: 1px solid rgba(26,22,18,0.05);"><td style="padding: 16px 0;">Cairo, EG</td><td style="padding: 16px 0; text-align: right;">$32,000</td></tr>
                        </tbody>
                    </table>
                </div>
                @if (!Model.HasContributedSalary)
                {
                    <div class="lock-overlay" style="background: rgba(237,232,223,0.4);">
                        <span style="background: var(--ink); color: var(--parchment); padding: 6px 12px; font-size: 10px; font-weight: 700; letter-spacing: 0.1em; border: var(--border);">LOCKED INSIGHT</span>
                    </div>
                }
            </div>
        </div>

        <div>
            <h2 class="section-title">Top Companies Hiring</h2>
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
                @foreach (var company in new[] { "Vodafone", "Valeo", "Talabat", "Instabug", "Careem", "Google" })
                {
                    <div class="company-pill">
                        <div class="company-icon">@company[0]</div>
                        <span>@company</span>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        @if (Model.Trend.Any())
        {
            <text>
            const trendCtx = document.getElementById('demandTrendChart').getContext('2d');
            new Chart(trendCtx, {
                type: 'line',
                data: {
                    labels: @Html.Raw(JsonSerializer.Serialize(Model.Trend.Select(t => t.SnapshotDate.ToString("MM.dd")))),
                    datasets: [{
                        data: @Html.Raw(JsonSerializer.Serialize(Model.Trend.Select(t => t.PostingCount))),
                        borderColor: '#1A1612',
                        backgroundColor: 'rgba(242, 112, 138, 0.1)',
                        fill: true,
                        tension: 0.4,
                        borderWidth: 3,
                        pointRadius: 0,
                        pointHoverRadius: 6,
                        pointHoverBackgroundColor: '#F2708A',
                        pointHoverBorderColor: '#1A1612',
                        pointHoverBorderWidth: 2
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        y: { 
                            beginAtZero: false, 
                            grid: { color: 'rgba(26,22,18,0.05)', drawBorder: false },
                            ticks: { font: { family: 'DM Sans', size: 10 }, color: 'rgba(26,22,18,0.4)' }
                        },
                        x: { 
                            grid: { display: false },
                            ticks: { font: { family: 'DM Sans', size: 10 }, color: 'rgba(26,22,18,0.4)' }
                        }
                    }
                }
            });
            </text>
        }

        const skillsCtx = document.getElementById('roleSkillsChart').getContext('2d');
        new Chart(skillsCtx, {
            type: 'bar',
            data: {
                labels: @Html.Raw(JsonSerializer.Serialize(Model.CommonSkills.Select(s => s.Name))),
                datasets: [{
                    data: [95, 88, 76, 65, 54, 42, 38, 25],
                    backgroundColor: '#1A1612',
                    hoverBackgroundColor: '#F2708A',
                    borderRadius: 0,
                    barThickness: 20
                }]
            },
            options: {
                indexAxis: 'y',
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    x: { display: false, beginAtZero: true },
                    y: { 
                        grid: { display: false },
                        ticks: { font: { family: 'DM Sans', size: 11, weight: 'bold' }, color: '#1A1612' }
                    }
                }
            }
        });
    </script>
}
