@using System.Text.Json
@model Jobalatica.Models.ViewModels.RankingsViewModel
@{
    ViewData["Title"] = "Market Rankings";
}

<style>
    /* PAGE HEADER */
    .page-header { border-bottom: var(--border); display: flex; flex-direction: column; align-items: center; text-align: center; padding: 96px 56px; }
    .page-label { display: flex; align-items: center; gap: 7px; font-size: 12px; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(26,22,18,0.45); margin-bottom: 24px; }
    .page-label-dot { width: 12px; height: 12px; background: var(--amber); display: inline-block; }
    .page-title { font-family: var(--serif); font-size: clamp(60px, 8vw, 110px); font-weight: 900; line-height: 0.95; letter-spacing: -0.04em; margin-bottom: 24px; }
    .page-title em { font-style: italic; font-weight: 400; }
    .page-sub { font-size: 1.1rem; font-weight: 300; color: rgba(26,22,18,0.55); max-width: 600px; margin-bottom: 48px; }
    .page-header-right { padding: 0; display: flex; align-items: center; justify-content: center; width: 100%; }

    /* ROLES ANALYSIS */
    .roles-section { border-bottom: var(--border); display: flex; flex-direction: column; }
    .chart-panel { border-right: none; border-bottom: var(--border); padding: 96px 56px; display: flex; flex-direction: column; align-items: center; }
    .chart-label { font-size: 12px; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(26,22,18,0.4); margin-bottom: 32px; display: flex; align-items: center; gap: 10px; width: 100%; max-width: 1000px; }
    
    /* TABLE */
    .roles-table { width: 100%; border-collapse: collapse; max-width: 1000px; margin: 0 auto; }
    .roles-table thead tr { border-bottom: var(--border); background: var(--parchment-2); }
    .roles-table th { padding: 24px 32px; font-size: 11px; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(26,22,18,0.4); text-align: left; }
    .roles-table td { padding: 32px 32px; font-size: 16px; border-bottom: 1px solid rgba(26,22,18,0.08); }
    .roles-table td:first-child { font-family: var(--serif); font-size: 32px; font-weight: 900; color: rgba(26,22,18,0.15); text-align: center; width: 80px; }
    .roles-table tr:hover td { background: var(--parchment-2); }

    /* SKILLS */
    .skills-intro { border-bottom: var(--border); display: grid; grid-template-columns: 300px 1fr; }
    .skills-intro-left { border-right: var(--border); padding: 48px 40px; background: var(--amber); }
    .skills-grid { display: grid; grid-template-columns: repeat(4, 1fr); border-bottom: var(--border); }
    .skill-card { border-right: var(--border); border-bottom: var(--border); padding: 28px 28px; }
    .skill-card:nth-child(4n) { border-right: none; }
    .skill-card:nth-last-child(-n+4) { border-bottom: none; }
    .skill-category { font-size: 9px; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(26,22,18,0.35); margin-bottom: 8px; }
    .skill-name { font-family: var(--serif); font-size: 22px; font-weight: 900; letter-spacing: -0.02em; margin-bottom: 8px; color: var(--ink); }
    .skill-count { font-size: 11px; color: rgba(26,22,18,0.5); margin-bottom: 12px; }
</style>

<!-- PAGE HEADER -->
<div class="page-header">
    <div class="page-label"><span class="page-label-dot"></span>Market Intelligence</div>
    <h1 class="page-title"><em>Role</em> Rankings</h1>
    <p class="page-sub">Analysis based on the last 30 days of market activity across 12,400+ verified postings.</p>
    
    <div style="width: 100%; max-width: 600px; margin-bottom: 48px; position: relative;">
        <form asp-action="Search" method="get" style="display: flex; gap: 0; border: var(--border); box-shadow: var(--shadow-sm); background: var(--parchment);">
            <input type="text" name="title" id="roleSearchInput" list="job-suggestions" autocomplete="off"
                   placeholder="Search any role for intelligence (e.g. 'Data Analyst')" 
                   style="flex: 1; padding: 20px; border: none; background: transparent; font-family: var(--sans); font-size: 16px; outline: none;" required />
            <datalist id="job-suggestions"></datalist>
            <button type="submit" class="btn" style="border: none; border-left: var(--border); background: var(--ink); color: var(--parchment); padding: 0 32px; border-radius: 0; font-weight: 900;">
                ANALYZE →
            </button>
        </form>
    </div>

    <script>
        document.getElementById('roleSearchInput').addEventListener('input', async function(e) {
            const val = e.target.value;
            if (val.length < 2) return;

            const response = await fetch(`/Rankings/Autocomplete?term=${encodeURIComponent(val)}`);
            const suggestions = await response.json();
            
            const datalist = document.getElementById('job-suggestions');
            datalist.innerHTML = '';
            suggestions.forEach(s => {
                const option = document.createElement('option');
                option.value = s;
                datalist.appendChild(option);
            });
        });
    </script>

    <div class="page-header-right">
        <div style="display: flex; border: var(--border); box-shadow: var(--shadow-sm);">
            <button class="btn" style="border: none; box-shadow: none; background: var(--ink); color: var(--parchment); border-radius: 0;">Monthly Analysis</button>
        </div>
    </div>
</div>

<div class="roles-section">
    <!-- BAR CHART -->
    <div class="chart-panel">
        <div class="chart-label">
            <svg width="8" height="8" viewBox="0 0 8 8"><rect width="8" height="8" fill="#1A1612"/></svg>
            Postings Volume — Top Roles
        </div>
        <div style="height: 600px; width: 100%; max-width: 1000px;">
            <canvas id="topRolesChart"></canvas>
        </div>
    </div>

    <!-- ROLES TABLE -->
    <div style="overflow: hidden;">
        <table class="roles-table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Role Title</th>
                    <th>Postings</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody id="rolesTableBody">
                @for (int i = 0; i < Model.TopRoles.Count; i++)
                {
                    var role = Model.TopRoles[i];
                    <tr class="role-row @(i >= 7 ? "hidden-role" : "")" style="@(i >= 7 ? "display: none;" : "")">
                        <td>@(i + 1)</td>
                        <td><span style="font-weight: 600; color: var(--ink);">@role.Title</span></td>
                        <td><span style="font-family: var(--serif); font-size: 16px; font-weight: 700;">@role.Count</span></td>
                        <td><a asp-controller="Rankings" asp-action="RoleDetail" asp-route-title="@role.Title" style="font-size: 10px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--ink); text-decoration: none; border-bottom: 1px solid var(--ink);">Details →</a></td>
                    </tr>
                }
            </tbody>
        </table>
        @if (Model.TopRoles.Count > 7)
        {
            <div id="showMoreContainer" style="padding: 32px; border-top: var(--border); text-align: center; background: var(--parchment-2);">
                <button class="btn" onclick="showAllRoles()" style="background: var(--ink); color: var(--parchment); padding: 12px 32px;">Read More Roles ↓</button>
            </div>
        }
    </div>
</div>

<script>
    function showAllRoles() {
        document.querySelectorAll('.hidden-role').forEach(row => {
            row.style.display = 'table-row';
        });
        document.getElementById('showMoreContainer').style.display = 'none';
    }
</script>

<!-- INDUSTRY SKILLS SECTION -->
<div class="skills-intro">
    <div class="skills-intro-left">
        <div style="font-size:10px;font-weight:700;letter-spacing:0.2em;text-transform:uppercase;color:rgba(26,22,18,0.5);margin-bottom:12px;display:flex;align-items:center;gap:8px;">
            <svg width="10" height="10" viewBox="0 0 10 10"><rect width="10" height="10" fill="#1A1612"/></svg>
            Skill Matrices
        </div>
        <h2 style="font-family:var(--serif);font-size:36px;font-weight:900;line-height:1.05;letter-spacing:-0.03em;margin-bottom:14px;">Industry<br/>Skills Index</h2>
        <p style="font-size:13px;font-weight:300;line-height:1.7;color:rgba(26,22,18,0.65);">Demand frequency across all active listings, updated weekly.</p>
    </div>
    <div style="padding: 48px 40px; display: flex; align-items: center;">
        <p style="font-size:15px;font-weight:300;line-height:1.8;color:rgba(26,22,18,0.55);max-width:480px;">
            We track every skill by demand frequency, salary delta, and market velocity — so you know exactly where to invest your learning time.
        </p>
    </div>
</div>
<div class="skills-grid">
    @foreach (var skill in Model.TopSkills)
    {
        <div class="skill-card">
            <div class="skill-category">@skill.Category</div>
            <div class="skill-name">@skill.Name</div>
            <div class="skill-count">@skill.TotalJobMentions postings</div>
            <span style="display: inline-block; padding: 3px 10px; font-size: 9px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; border: var(--border); background: var(--green);">High Demand</span>
        </div>
    }
</div>

@section Scripts {
    <script>
        const labels = @Html.Raw(JsonSerializer.Serialize(Model.TopRoles.Select(r => r.Title)));
        const data = @Html.Raw(JsonSerializer.Serialize(Model.TopRoles.Select(r => r.Count)));

        new Chart(document.getElementById('topRolesChart'), {
            type: 'bar',
            data: {
                labels: labels,
                datasets: [{
                    data: data,
                    backgroundColor: '#1A1612',
                    borderWidth: 0,
                }]
            },
            options: {
                indexAxis: 'y',
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    x: { display: false, beginAtZero: true },
                    y: {
                        grid: { display: false },
                        ticks: { color: 'rgba(26,22,18,0.5)', font: { family: 'DM Sans', size: 12, weight: 'bold' } }
                    }
                }
            }
        });
    </script>
}
