@model Jobalatica.Models.Entities.Job
@inject Jobalatica.Services.ISalaryEstimator SalaryEstimator
@{
    bool isSaved = ViewData["IsSaved"] as bool? ?? false;
    bool isNew = (DateTime.UtcNow - Model.PostedAt).TotalDays < 2;
    var est = SalaryEstimator.GetEstimate(Model);
}

<div style="display: grid; grid-template-columns: 1fr 1fr auto; align-items: start; gap: 48px; width: 100%;">
    <!-- COL 1: CORE IDENTITY -->
    <div style="min-width: 0;">
        <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 12px;">
            @if (isNew)
            {
                <span style="display: inline-block; background: var(--green); border: var(--border); padding: 2px 8px; font-size: 9px; font-weight: 900; letter-spacing: 0.05em; text-transform: uppercase;">New Signal</span>
            }
            <span style="display: inline-block; border: 1px solid rgba(26,22,18,0.25); padding: 4px 10px; font-size: 11px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink);">@Model.ExperienceLevel</span>
            <span style="font-size: 13px; color: rgba(26,22,18,0.45); font-weight: 500;">@Model.PostedAt.ToString("MM.dd.yy")</span>
        </div>
        <div style="font-family: var(--serif); font-size: 28px; font-weight: 700; letter-spacing: -0.02em; margin-bottom: 4px; color: var(--ink); white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
            <a asp-controller="Jobs" asp-action="Detail" asp-route-id="@Model.Id" style="text-decoration: none; color: inherit;">@Model.Title</a>
        </div>
        <div style="font-size: 13px; font-weight: 600; letter-spacing: 0.15em; text-transform: uppercase; color: rgba(26,22,18,0.5); margin-bottom: 6px;">@Model.Company · @Model.Location</div>
        <div style="font-size: 14px; color: rgba(26,22,18,0.6); font-weight: 400;">○ @Model.SourceSite · Full-time</div>
    </div>

    <!-- COL 2: MARKET CONTEXT (THE BRIDGE) -->
    <div style="padding-top: 8px;">
        <div style="margin-bottom: 12px;">
            <span style="font-size: 10px; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; color: rgba(26,22,18,0.3); display: block; margin-bottom: 8px;">Primary Tech Stack</span>
            <div style="display: flex; flex-wrap: wrap; gap: 8px;">
                @foreach (var js in Model.JobSkills.Take(5))
                {
                    <span style="padding: 4px 12px; border: 1px solid rgba(26,22,18,0.15); font-size: 12px; font-weight: 600; color: rgba(26,22,18,0.55); background: var(--parchment-2);">@js.Skill.Name</span>
                }
            </div>
        </div>
        <div style="display: flex; align-items: center; gap: 6px;">
            <div style="width: 6px; height: 6px; border-radius: 50%; background: var(--green);"></div>
            <span style="font-size: 11px; font-weight: 700; color: var(--ink); opacity: 0.6;">Verified Market Data</span>
        </div>
    </div>

    <!-- COL 3: VALUE & ACTIONS -->
    <div style="display: flex; flex-direction: column; align-items: flex-end; gap: 16px; min-width: 240px;">
        <div style="font-family: var(--serif); font-size: 26px; font-weight: 700; letter-spacing: -0.02em; text-align: right; white-space: nowrap; color: var(--ink);">
            @if (Model.SalaryMin.HasValue)
            {
                <span>$@((Model.SalaryMin.Value / 1000).ToString("N0"))K — @((Model.SalaryMax / 1000)?.ToString("N0"))K</span>
                <span style="display: block; font-family: var(--sans); font-size: 12px; font-weight: 500; color: rgba(26,22,18,0.45); letter-spacing: 0.08em; text-transform: uppercase; margin-top: 2px;">@Model.Currency / Year</span>
            }
            else if (est != null)
            {
                <span style="color: rgba(26,22,18,0.6);">$@((est.EstimatedSalaryMin / 1000).ToString("N0"))K — @((est.EstimatedSalaryMax / 1000).ToString("N0"))K</span>
                <span style="display: block; font-family: var(--sans); font-size: 10px; font-weight: 700; color: var(--pink); letter-spacing: 0.08em; text-transform: uppercase; margin-top: 2px;">AI Estimate</span>
            }
        </div>
        <div style="display: flex; gap: 10px; align-items: center;">
            @if (User.Identity?.IsAuthenticated == true)
            {
                <button class="save-job-btn @(isSaved ? "is-saved" : "")" 
                        hx-post="/Jobs/@(isSaved ? "Unsave" : "Save")?jobId=@Model.Id"
                        hx-swap="none"
                        hx-on::after-request="this.classList.toggle('is-saved'); let svg = this.querySelector('svg'); if(this.classList.contains('is-saved')) { svg.setAttribute('fill', '#F2708A'); this.setAttribute('hx-post', '/Jobs/Unsave?jobId=@Model.Id'); this.style.background='#F2708A'; } else { svg.setAttribute('fill', 'none'); this.setAttribute('hx-post', '/Jobs/Save?jobId=@Model.Id'); this.style.background='var(--parchment)'; } htmx.process(this);"
                        style="width: 44px; height: 44px; border: var(--border); background: @(isSaved ? "#F2708A" : "var(--parchment)"); display: grid; place-items: center; cursor: pointer; transition: all 0.15s;" 
                        onmouseenter="if(!this.classList.contains('is-saved')) this.style.background='var(--pink)'; this.style.transform='translateY(-2px)'" 
                        onmouseleave="if(!this.classList.contains('is-saved')) this.style.background='var(--parchment)'; this.style.transform=''" 
                        title="@(isSaved ? "Unsave" : "Save")">
                    <svg viewBox="0 0 24 24" width="20" height="20" fill="@(isSaved ? "#F2708A" : "none")" stroke="#1A1612" stroke-width="2.5"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                </button>
            }
            else
            {
                <button onclick="window.location.href='/Account/Login'" style="width: 44px; height: 44px; border: var(--border); background: var(--parchment); display: grid; place-items: center; cursor: pointer; transition: all 0.15s;" onmouseenter="this.style.background='var(--pink)'; this.style.transform='translateY(-2px)'" onmouseleave="this.style.background='var(--parchment)'; this.style.transform=''" title="Login to Save">
                    <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="#1A1612" stroke-width="2.5"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                </button>
            }
            <a asp-controller="Jobs" asp-action="Detail" asp-route-id="@Model.Id" class="btn" style="padding: 12px 24px; font-size: 12px; box-shadow: var(--shadow-sm);">View Details →</a>
        </div>
    </div>
</div>
