@model Jobalatica.Models.ViewModels.JobDetailViewModel
@{
    ViewData["Title"] = Model.Job.Title;
}

<div class="max-w-5xl mx-auto">
    <!-- Header Card -->
    <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-700 p-8 mb-8">
        <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6">
            <div>
                <div class="flex items-center gap-3 mb-2">
                    <span class="bg-blue-100 text-blue-800 text-xs font-bold px-2.5 py-0.5 rounded dark:bg-blue-900 dark:text-blue-300">@Model.Job.ExperienceLevel</span>
                    <span class="text-xs text-gray-400">Posted @Model.Job.PostedAt.ToString("MMM dd, yyyy")</span>
                </div>
                <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-2">@Model.Job.Title</h1>
                <div class="flex flex-wrap items-center gap-y-2 text-gray-600 dark:text-gray-400">
                    <span class="font-semibold text-lg mr-4">@Model.Job.Company</span>
                    <span class="flex items-center">
                        <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                        @Model.Job.Location, @Model.Job.Country
                    </span>
                </div>
            </div>
            
            <div class="flex flex-wrap gap-3 w-full md:w-auto">
                <a href="@Model.Job.SourceUrl" target="_blank" class="flex-grow md:flex-grow-0 text-white bg-blue-700 hover:bg-blue-800 focus:ring-4 focus:ring-blue-300 font-bold rounded-lg text-sm px-6 py-3.5 dark:bg-blue-600 dark:hover:bg-blue-700 focus:outline-none flex items-center justify-center">
                    Visit Original Posting
                    <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
                </a>
                
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <button id="save-btn" 
                            hx-post="/Jobs/@(Model.IsSaved ? "Unsave" : "Save")?jobId=@Model.Job.Id"
                            hx-swap="none"
                            class="flex-grow md:flex-grow-0 border-2 @(Model.IsSaved ? "border-red-500 text-red-500" : "border-gray-200 text-gray-500") hover:bg-gray-50 font-bold rounded-lg text-sm px-6 py-3.5 transition-colors flex items-center justify-center">
                        <svg class="w-5 h-5 mr-2" fill="@(Model.IsSaved ? "currentColor" : "none")" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path></svg>
                        @(Model.IsSaved ? "Saved" : "Save Job")
                    </button>
                }
            </div>
        </div>
        
        <div class="mt-8 pt-8 border-t border-gray-100 dark:border-gray-700">
            <div class="flex flex-col md:flex-row gap-8">
                <div class="flex-grow">
                    <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-4">Required Skills</h3>
                    <div class="flex flex-wrap gap-2">
                        @foreach (var js in Model.Job.JobSkills)
                        {
                            <a href="/Rankings/RoleDetail?title=@js.Skill.Name" class="bg-blue-50 text-blue-700 hover:bg-blue-100 px-4 py-2 rounded-lg text-sm font-bold transition-colors border border-blue-100">
                                @js.Skill.Name
                            </a>
                        }
                    </div>
                </div>
                
                <div class="md:w-64">
                    <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-4">Market Demand</h3>
                    <div class="w-full bg-gray-200 rounded-full h-4 dark:bg-gray-700 mb-2">
                        <div class="bg-blue-600 h-4 rounded-full" style="width: @(Math.Min(Model.Job.JobSkills.Count * 15, 100))%"></div>
                    </div>
                    <p class="text-xs text-gray-500">Demand Score: @(Math.Min(Model.Job.JobSkills.Count * 15, 100))/100 based on required skills.</p>
                </div>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 mb-12">
        <!-- Body Content -->
        <div class="lg:col-span-2 space-y-8">
            <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-700 p-8">
                <h2 class="text-2xl font-bold mb-6">About This Role</h2>
                <div class="prose dark:prose-invert max-w-none text-gray-600 dark:text-gray-400">
                    <p class="mb-4">This job was collected from <strong>@Model.Job.SourceSite</strong>. We analyze roles like this to help you understand market trends.</p>
                    <p class="mb-4">To view the full description and apply, please visit the original posting using the button above.</p>
                    <h4 class="text-gray-900 dark:text-white font-bold mt-6 mb-2">Why we like this role:</h4>
                    <ul class="list-disc ml-5 space-y-2">
                        <li>High transparency in @Model.Job.SourceSite posting.</li>
                        <li>Strong focus on core technologies like @string.Join(", ", Model.Job.JobSkills.Take(2).Select(s => s.Skill.Name)).</li>
                        <li>Clear @Model.Job.ExperienceLevel level expectations.</li>
                    </ul>
                </div>
            </div>
            
            <!-- Salary Intelligence -->
            <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-700 p-8">
                <h2 class="text-2xl font-bold mb-6">Salary Intelligence</h2>
                <div class="flex flex-col md:flex-row gap-8 items-center">
                    <div class="flex-grow w-full">
                        <div class="flex justify-between text-sm font-bold text-gray-500 mb-2">
                            <span>Market Average</span>
                            <span>Posted Range</span>
                        </div>
                        <div class="relative h-12 bg-gray-100 dark:bg-gray-700 rounded-xl overflow-hidden mb-2">
                            @if (Model.Job.SalaryMin.HasValue && Model.Job.SalaryMax.HasValue)
                            {
                                <div class="absolute h-full bg-blue-100 dark:bg-blue-900 border-x-2 border-blue-500 opacity-50" style="left: 30%; right: 20%"></div>
                                <div class="absolute top-1/2 -translate-y-1/2 w-4 h-4 bg-blue-600 rounded-full shadow-lg" style="left: 45%"></div>
                            }
                            else
                            {
                                <div class="flex items-center justify-center h-full italic text-gray-400">Salary data not provided for this posting</div>
                            }
                        </div>
                        <div class="flex justify-between text-xs text-gray-400">
                            <span>$40k</span>
                            <span>$80k</span>
                            <span>$120k</span>
                        </div>
                    </div>
                    
                    <div class="md:w-48 text-center p-4 bg-blue-50 dark:bg-blue-900 rounded-xl border border-blue-100 dark:border-blue-800">
                        <span class="block text-sm text-blue-600 dark:text-blue-300 font-bold uppercase tracking-wide mb-1">Estimated Range</span>
                        <span class="text-2xl font-extrabold text-blue-800 dark:text-white">
                            @(Model.Job.SalaryMin.HasValue ? $"{Model.Job.SalaryMin?.ToString("N0")}" : "???") - @(Model.Job.SalaryMax.HasValue ? $"{Model.Job.SalaryMax?.ToString("N0")}" : "???")
                        </span>
                        <span class="block text-xs text-blue-600 dark:text-blue-400 mt-1">@Model.Job.Currency / year</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Sidebar Content -->
        <div class="space-y-8">
            <!-- Skill Demand Chart -->
            <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-700 p-6">
                <h3 class="text-lg font-bold mb-6">Role Skill Demand</h3>
                <canvas id="skillDemandChart" height="200"></canvas>
                <p class="text-xs text-gray-400 mt-4 italic">Comparison of required skills against top industry trends.</p>
            </div>
            
            <!-- Similar Jobs -->
            <div>
                <h3 class="text-xl font-bold mb-6">Similar Jobs</h3>
                <div class="space-y-4">
                    @foreach (var similar in Model.SimilarJobs)
                    {
                        <div class="bg-white dark:bg-gray-800 p-4 rounded-xl border border-gray-100 dark:border-gray-700 shadow-sm hover:shadow-md transition-shadow">
                            <h4 class="font-bold text-gray-900 dark:text-white mb-1">
                                <a asp-action="Detail" asp-route-id="@similar.Id" class="hover:text-blue-600">@similar.Title</a>
                            </h4>
                            <p class="text-sm text-gray-500 mb-2">@similar.Company</p>
                            <div class="flex justify-between items-center">
                                <span class="text-xs font-mono text-green-600">@similar.Location</span>
                                <a asp-action="Detail" asp-route-id="@similar.Id" class="text-xs font-bold text-blue-600">View →</a>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Skill Demand Chart
        const ctx = document.getElementById('skillDemandChart').getContext('2d');
        new Chart(ctx, {
            type: 'radar',
            data: {
                labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Job.JobSkills.Take(5).Select(s => s.Skill.Name))),
                datasets: [{
                    label: 'This Role',
                    data: [90, 85, 95, 70, 80],
                    backgroundColor: 'rgba(59, 130, 246, 0.2)',
                    borderColor: 'rgb(59, 130, 246)',
                    pointBackgroundColor: 'rgb(59, 130, 246)',
                }, {
                    label: 'Market Average',
                    data: [70, 75, 60, 80, 65],
                    backgroundColor: 'rgba(156, 163, 175, 0.2)',
                    borderColor: 'rgb(156, 163, 175)',
                    pointBackgroundColor: 'rgb(156, 163, 175)',
                }]
            },
            options: {
                plugins: {
                    legend: { display: false }
                },
                scales: {
                    r: {
                        angleLines: { display: false },
                        suggestedMin: 0,
                        suggestedMax: 100,
                        ticks: { display: false }
                    }
                }
            }
        });

        // Toggle Save Button
        document.addEventListener('htmx:afterRequest', function(evt) {
            if (evt.detail.target.id === 'save-btn') {
                const btn = evt.detail.target;
                const isSaved = btn.innerText.trim() === 'Saved';
                
                if (evt.detail.successful) {
                    if (isSaved) {
                        btn.innerText = 'Save Job';
                        btn.classList.remove('border-red-500', 'text-red-500');
                        btn.classList.add('border-gray-200', 'text-gray-500');
                        btn.setAttribute('hx-post', '/Jobs/Save?jobId=@Model.Job.Id');
                        btn.querySelector('svg').setAttribute('fill', 'none');
                    } else {
                        btn.innerText = 'Saved';
                        btn.classList.remove('border-gray-200', 'text-gray-500');
                        btn.classList.add('border-red-500', 'text-red-500');
                        btn.setAttribute('hx-post', '/Jobs/Unsave?jobId=@Model.Job.Id');
                        btn.querySelector('svg').setAttribute('fill', 'currentColor');
                    }
                    // Re-process htmx for the updated attribute
                    htmx.process(btn);
                }
            }
        });
    </script>
}
