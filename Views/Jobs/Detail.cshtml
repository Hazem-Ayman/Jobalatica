@model Jobalatica.Models.ViewModels.JobDetailViewModel
@inject Jobalatica.Services.ISalaryEstimator SalaryEstimator
@{
    ViewData["Title"] = Model.Job.Title;
    var est = SalaryEstimator.GetEstimate(Model.Job);
}

<style>
    .detail-container { max-width: 1100px; margin: 0 auto; padding: 40px 20px; }
    
    .card-brutal { 
        background: var(--parchment); 
        border: var(--border); 
        box-shadow: var(--shadow); 
        padding: 40px; 
        margin-bottom: 40px; 
        position: relative;
    }

    .detail-header-label { 
        display: flex; 
        align-items: center; 
        gap: 8px; 
        font-size: 11px; 
        font-weight: 700; 
        letter-spacing: 0.15em; 
        text-transform: uppercase; 
        color: rgba(26,22,18,0.5); 
        margin-bottom: 20px; 
    }
    .detail-header-dot { width: 10px; height: 10px; background: var(--green); }

    .detail-title { 
        font-family: var(--serif); 
        font-size: clamp(32px, 5vw, 56px); 
        font-weight: 900; 
        line-height: 1.1; 
        letter-spacing: -0.03em; 
        margin-bottom: 16px; 
        color: var(--ink); 
    }
    .detail-company-row { 
        display: flex; 
        flex-wrap: wrap; 
        align-items: center; 
        gap: 15px; 
        font-size: 15px; 
        font-weight: 500; 
        color: var(--ink); 
        margin-bottom: 32px;
    }
    .detail-company-name { font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; }
    .detail-location { color: rgba(26,22,18,0.5); }

    .btn-brutal { 
        display: inline-flex; 
        align-items: center; 
        gap: 10px; 
        padding: 14px 28px; 
        font-family: var(--sans); 
        font-size: 13px; 
        font-weight: 700; 
        letter-spacing: 0.1em; 
        text-transform: uppercase; 
        border: var(--border); 
        cursor: pointer; 
        transition: all 0.15s; 
        text-decoration: none;
        color: var(--ink);
    }
    .btn-brutal-primary { background: var(--pink); box-shadow: var(--shadow-sm); }
    .btn-brutal-primary:hover { transform: translate(-2px, -2px); box-shadow: 6px 6px 0 var(--ink); }
    
    .btn-brutal-secondary { background: var(--parchment); box-shadow: var(--shadow-sm); }
    .btn-brutal-secondary:hover { transform: translate(-2px, -2px); box-shadow: 6px 6px 0 var(--ink); }
    .btn-brutal-secondary.is-saved { background: var(--pink); }

    .section-label { 
        font-size: 10px; 
        font-weight: 700; 
        letter-spacing: 0.2em; 
        text-transform: uppercase; 
        color: rgba(26,22,18,0.4); 
        margin-bottom: 24px; 
        display: flex; 
        align-items: center; 
        gap: 8px; 
    }

    .skill-pill { 
        padding: 8px 16px; 
        border: 1px solid rgba(26,22,18,0.2); 
        font-size: 13px; 
        font-weight: 600; 
        color: var(--ink); 
        background: rgba(26,22,18,0.03); 
        display: inline-block;
    }

    .prose-brutal { font-size: 16px; line-height: 1.8; color: rgba(26,22,18,0.7); }
    .prose-brutal h4 { font-family: var(--serif); font-size: 20px; font-weight: 700; color: var(--ink); margin-top: 32px; margin-bottom: 12px; }
    .prose-brutal ul { padding-left: 20px; margin-top: 16px; }
    .prose-brutal li { margin-bottom: 12px; }

    .salary-box { 
        background: var(--ink); 
        color: var(--parchment); 
        padding: 32px; 
        text-align: center; 
        border: var(--border); 
        box-shadow: var(--shadow-sm); 
    }
    .salary-estimate-label { font-size: 11px; font-weight: 600; letter-spacing: 0.15em; text-transform: uppercase; color: rgba(237,232,223,0.5); margin-bottom: 8px; display: block; }
    .salary-range-text { font-family: var(--serif); font-size: 32px; font-weight: 900; letter-spacing: -0.02em; }

    .similar-job-card { 
        border: var(--border); 
        padding: 24px; 
        margin-bottom: 16px; 
        background: var(--parchment); 
        transition: all 0.15s; 
        text-decoration: none; 
        display: block; 
        color: var(--ink); 
    }
    .similar-job-card:hover { transform: translate(-2px, -2px); box-shadow: var(--shadow-sm); background: var(--parchment-2); }
</style>

<div class="detail-container">
    <!-- Header Section -->
    <div class="card-brutal">
        <div class="detail-header-label">
            <div class="detail-header-dot"></div>
            Verified Signal — @Model.Job.PostedAt.ToString("MMM dd, yyyy")
        </div>
        
        <div style="display: flex; flex-direction: column; md:flex-direction: row; justify-content: space-between; align-items: flex-start; gap: 40px;">
            <div style="flex: 1;">
                <h1 class="detail-title">@Model.Job.Title</h1>
                <div class="detail-company-row">
                    <span class="detail-company-name">@Model.Job.Company</span>
                    <span style="color: rgba(26,22,18,0.2);">|</span>
                    <span class="detail-location">@Model.Job.Location, @Model.Job.Country</span>
                    <span style="color: rgba(26,22,18,0.2);">|</span>
                    <span style="font-weight: 700; font-size: 12px; text-transform: uppercase; letter-spacing: 0.05em;">@Model.Job.ExperienceLevel</span>
                </div>
                
                <div class="flex flex-wrap gap-4 mt-8">
                    <a href="@Model.Job.SourceUrl" target="_blank" class="btn-brutal btn-brutal-primary">
                        Visit Original Posting
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6M15 3h6v6M10 14L21 3"/></svg>
                    </a>
                    
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <button id="save-btn" 
                                hx-post="/Jobs/@(Model.IsSaved ? "Unsave" : "Save")?jobId=@Model.Job.Id"
                                hx-swap="none"
                                class="btn-brutal btn-brutal-secondary @(Model.IsSaved ? "is-saved" : "")">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="@(Model.IsSaved ? "currentColor" : "none")" stroke="currentColor" stroke-width="2.5"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                            @(Model.IsSaved ? "Saved to Matrix" : "Save Signal")
                        </button>
                    }
                </div>
            </div>
        </div>

        <div style="margin-top: 48px; padding-top: 32px; border-top: 1px solid rgba(26,22,18,0.1); display: grid; grid-template-columns: 1fr 280px; gap: 40px;">
            <div>
                <div class="section-label">Required Tech Stack</div>
                <div style="display: flex; flex-wrap: wrap; gap: 10px;">
                    @foreach (var js in Model.Job.JobSkills)
                    {
                        <span class="skill-pill">@js.Skill.Name</span>
                    }
                </div>
            </div>
            <div>
                <div class="section-label">Market Velocity</div>
                <div style="height: 12px; background: var(--parchment-2); border: 1px solid var(--ink); position: relative; margin-bottom: 12px;">
                    <div style="position: absolute; top: 0; left: 0; bottom: 0; background: var(--ink); width: @(Math.Min(Model.Job.JobSkills.Count * 15, 100))%"></div>
                </div>
                <div style="font-size: 11px; font-weight: 500; color: rgba(26,22,18,0.5);">Demand Score: @(Math.Min(Model.Job.JobSkills.Count * 15, 100))/100</div>
            </div>
        </div>
    </div>

    <div style="display: grid; grid-template-columns: 1fr 340px; gap: 40px;">
        <div class="space-y-10">
            <!-- About Section -->
            <div class="card-brutal">
                <h2 style="font-family: var(--serif); font-size: 32px; font-weight: 900; margin-bottom: 24px;">About This Role</h2>
                <div class="prose-brutal">
                    <p>This job was collected from <strong>@Model.Job.SourceSite</strong>. We analyze roles like this to help the collective understand market trends and demand velocity.</p>
                    <p>To view the full description and apply, please visit the original posting using the primary action button.</p>
                    
                    <h4>Intelligence Summary</h4>
                    <ul>
                        <li>High data transparency in @Model.Job.SourceSite reporting.</li>
                        <li>Strong focus on core technologies like @string.Join(", ", Model.Job.JobSkills.Take(2).Select(s => s.Skill.Name)).</li>
                        <li>Standardized @Model.Job.ExperienceLevel level expectations.</li>
                    </ul>
                </div>
            </div>

            <!-- Salary Intelligence -->
            <div class="card-brutal">
                <h2 style="font-family: var(--serif); font-size: 32px; font-weight: 900; margin-bottom: 32px;">Value Intelligence</h2>
                <div style="display: flex; flex-direction: column; md:flex-direction: row; gap: 40px; align-items: stretch;">
                    <div style="flex: 1;">
                        <div style="display: flex; justify-content: space-between; font-size: 11px; font-weight: 700; text-transform: uppercase; color: rgba(26,22,18,0.4); margin-bottom: 12px;">
                            <span>Market Baseline</span>
                            <span>Posted Variance</span>
                        </div>
                        <div style="height: 60px; background: var(--parchment-2); border: var(--border); position: relative; display: flex; align-items: center; justify-content: center;">
                            @{
                                var chartMin = Model.Job.SalaryMin ?? Model.Job.EstimatedSalaryMin;
                                var chartMax = Model.Job.SalaryMax ?? Model.Job.EstimatedSalaryMax;
                            }
                            @if (chartMin.HasValue && chartMax.HasValue)
                            {
                                <div style="position: absolute; top: 0; bottom: 0; left: 30%; width: 40%; background: var(--lavender); opacity: 0.4; border-left: 1px solid var(--ink); border-right: 1px solid var(--ink);"></div>
                                <div style="width: 12px; height: 12px; background: var(--ink); position: absolute; left: 45%;"></div>
                            }
                            else
                            {
                                <span style="font-style: italic; color: rgba(26,22,18,0.3); font-size: 13px;">No salary baseline available</span>
                            }
                        </div>
                        <div style="display: flex; justify-content: space-between; font-size: 10px; font-weight: 600; color: rgba(26,22,18,0.3); margin-top: 12px;">
                            <span>$40K</span>
                            <span>$80K</span>
                            <span>$120K</span>
                        </div>
                    </div>
                    
                    <div class="salary-box" style="min-width: 240px;">
                        @if (Model.Job.SalaryMin.HasValue)
                        {
                            <span class="salary-estimate-label">Market Range</span>
                            <div class="salary-range-text">
                                $@((Model.Job.SalaryMin.Value / 1000).ToString("N0"))K — $@((Model.Job.SalaryMax / 1000)?.ToString("N0"))K
                            </div>
                            <span style="font-size: 11px; font-weight: 500; color: rgba(237,232,223,0.4); margin-top: 8px; display: block;">@Model.Job.Currency / YEAR</span>
                        }
                        else if (est != null)
                        {
                            <span class="salary-estimate-label">Estimated Range</span>
                            <div class="salary-range-text">
                                $@((est.EstimatedSalaryMin / 1000).ToString("N0"))K — $@((est.EstimatedSalaryMax / 1000).ToString("N0"))K
                            </div>
                            <span style="font-size: 11px; font-weight: 500; color: rgba(237,232,223,0.4); margin-top: 8px; display: block;">@Model.Job.Currency / YEAR</span>
                            <span style="font-size: 10px; font-weight: 700; color: var(--pink); margin-top: 4px; display: block;">AI Estimate</span>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="space-y-10">
            <!-- Chart Section -->
            <div class="card-brutal" style="padding: 24px;">
                <h3 style="font-family: var(--serif); font-size: 20px; font-weight: 900; margin-bottom: 24px;">Skill Demand Matrix</h3>
                <div style="height: 240px;">
                    <canvas id="skillDemandChart"></canvas>
                </div>
                <p style="font-size: 11px; color: rgba(26,22,18,0.4); margin-top: 20px; font-style: italic; line-height: 1.4;">
                    Comparison of signal-specific tech requirements against aggregate market benchmarks.
                </p>
            </div>

            <!-- Similar Signals -->
            <div>
                <h3 style="font-family: var(--serif); font-size: 24px; font-weight: 900; margin-bottom: 24px;">Similar Signals</h3>
                <div class="space-y-4">
                    @foreach (var similar in Model.SimilarJobs)
                    {
                        <a asp-action="Detail" asp-route-id="@similar.Id" class="similar-job-card">
                            <div style="font-family: var(--serif); font-size: 18px; font-weight: 700; margin-bottom: 4px;">@similar.Title</div>
                            <div style="font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: rgba(26,22,18,0.45); margin-bottom: 12px;">@similar.Company</div>
                            <div style="display: flex; justify-content: space-between; align-items: center;">
                                <span style="font-size: 12px; font-weight: 500;">@similar.Location</span>
                                <span style="font-size: 11px; font-weight: 700; color: var(--pink);">View →</span>
                            </div>
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Skill Demand Chart
        const ctx = document.getElementById('skillDemandChart').getContext('2d');
        new Chart(ctx, {
            type: 'radar',
            data: {
                labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Job.JobSkills.Take(5).Select(s => s.Skill.Name))),
                datasets: [{
                    label: 'This Signal',
                    data: [90, 85, 95, 70, 80],
                    backgroundColor: 'rgba(242, 112, 138, 0.2)',
                    borderColor: '#F2708A',
                    borderWidth: 2,
                    pointBackgroundColor: '#F2708A',
                }, {
                    label: 'Market Baseline',
                    data: [70, 75, 60, 80, 65],
                    backgroundColor: 'rgba(26, 22, 18, 0.05)',
                    borderColor: '#1A1612',
                    borderWidth: 2,
                    pointBackgroundColor: '#1A1612',
                }]
            },
            options: {
                plugins: { legend: { display: false } },
                scales: {
                    r: {
                        angleLines: { color: 'rgba(26,22,18,0.1)' },
                        grid: { color: 'rgba(26,22,18,0.1)' },
                        suggestedMin: 0,
                        suggestedMax: 100,
                        ticks: { display: false },
                        pointLabels: {
                            font: { family: 'DM Sans', size: 10, weight: 'bold' },
                            color: '#1A1612'
                        }
                    }
                }
            }
        });

        // Toggle Save Button
        document.addEventListener('htmx:afterRequest', function(evt) {
            if (evt.detail.target.id === 'save-btn') {
                const btn = evt.detail.target;
                const isSaved = btn.classList.contains('is-saved');
                
                if (evt.detail.successful) {
                    if (isSaved) {
                        btn.innerHTML = `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg> Save Signal`;
                        btn.classList.remove('is-saved');
                        btn.setAttribute('hx-post', '/Jobs/Save?jobId=@Model.Job.Id');
                    } else {
                        btn.innerHTML = `<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2.5"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg> Saved to Matrix`;
                        btn.classList.add('is-saved');
                        btn.setAttribute('hx-post', '/Jobs/Unsave?jobId=@Model.Job.Id');
                    }
                    htmx.process(btn);
                }
            }
        });
    </script>
}
