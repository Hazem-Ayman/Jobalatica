@model Jobalatica.Models.ViewModels.JobSearchViewModel

<div class="flex justify-between items-center mb-6">
    <h2 class="text-xl font-bold text-gray-900 dark:text-white">
        @Model.TotalCount Results Found
    </h2>
    
    <div class="flex items-center gap-2">
        <span class="text-sm text-gray-500">Sort by:</span>
        <select class="bg-transparent border-none text-sm font-semibold text-blue-600 focus:ring-0 cursor-pointer">
            <option>Newest First</option>
            <option>Highest Salary</option>
            <option>Relevant</option>
        </select>
    </div>
</div>

@if (!Model.Jobs.Any())
{
    <div class="bg-white dark:bg-gray-800 rounded-xl p-12 text-center border border-dashed border-gray-300 dark:border-gray-600">
        <svg class="w-16 h-16 text-gray-400 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
        <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-2">No jobs found matching your filters</h3>
        <p class="text-gray-600 dark:text-gray-400">Try adjusting your keywords or clearing some filters.</p>
    </div>
}
else
{
    <div class="grid grid-cols-1 gap-4 mb-8">
        @foreach (var job in Model.Jobs)
        {
            @await Html.PartialAsync("_JobCard", job)
        }
    </div>

    @if (Model.TotalPages > 1)
    {
        <nav class="flex justify-center items-center space-x-2">
            @if (Model.CurrentPage > 1)
            {
                <button hx-get="/Jobs?page=@(Model.CurrentPage - 1)&query=@Model.Query&location=@Model.Location&experienceLevel=@Model.ExperienceLevel&salaryMin=@Model.SalaryMin" 
                        hx-target="#job-results"
                        class="px-4 py-2 text-sm font-medium text-gray-500 bg-white border border-gray-300 rounded-lg hover:bg-gray-100 hover:text-gray-700 dark:bg-gray-800 dark:border-gray-700 dark:text-gray-400 dark:hover:bg-gray-700 dark:hover:text-white">
                    Previous
                </button>
            }

            <span class="text-sm text-gray-700 dark:text-gray-400">
                Page <span class="font-semibold text-gray-900 dark:text-white">@Model.CurrentPage</span> of <span class="font-semibold text-gray-900 dark:text-white">@Model.TotalPages</span>
            </span>

            @if (Model.CurrentPage < Model.TotalPages)
            {
                <button hx-get="/Jobs?page=@(Model.CurrentPage + 1)&query=@Model.Query&location=@Model.Location&experienceLevel=@Model.ExperienceLevel&salaryMin=@Model.SalaryMin" 
                        hx-target="#job-results"
                        class="px-4 py-2 text-sm font-medium text-gray-500 bg-white border border-gray-300 rounded-lg hover:bg-gray-100 hover:text-gray-700 dark:bg-gray-800 dark:border-gray-700 dark:text-gray-400 dark:hover:bg-gray-700 dark:hover:text-white">
                    Next
                </button>
            }
        </nav>
    }
}
