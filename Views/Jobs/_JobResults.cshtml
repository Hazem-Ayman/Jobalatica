@model Jobalatica.Models.ViewModels.JobSearchViewModel

<style>
    .results-bar { border-bottom: var(--border); padding: 20px 36px; display: flex; align-items: center; justify-content: space-between; background: var(--parchment); }
    .results-count { font-size: 13px; font-weight: 500; color: rgba(26,22,18,0.5); }
    .results-count strong { color: var(--ink); font-family: var(--serif); font-size: 18px; font-weight: 900; }
    .sort-row { display: flex; align-items: center; gap: 10px; font-size: 12px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: rgba(26,22,18,0.55); }
    .sort-select { padding: 8px 32px 8px 12px; font-family: var(--sans); font-size: 12px; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; background: var(--parchment); border: var(--border); outline: none; color: var(--ink); cursor: pointer; appearance: none; background-image: url("data:image/svg+xml,%3Csvg width='10' height='6' viewBox='0 0 10 6' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M0 0l5 6 5-6z' fill='%231A1612'/%3E%3C/svg%3E"); background-repeat: no-repeat; background-position: right 10px center; }

    .job-row { border-bottom: var(--border); padding: 16px 36px; transition: background 0.15s; }
    .job-row:hover { background: var(--parchment-2); }

    .pagination { border-top: var(--border); padding: 28px 36px; display: flex; align-items: center; justify-content: space-between; background: var(--parchment); }
    .page-btn { padding: 10px 20px; border: var(--border); font-size: 11px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; background: var(--parchment); cursor: pointer; transition: background 0.12s; border-radius: 0; }
    .page-btn:hover { background: var(--parchment-2); }
    .page-btn:disabled { opacity: 0.3; cursor: default; }
</style>

<div class="results-bar">
    <div class="results-count"><strong>@Model.TotalCount</strong>&nbsp; Results Found</div>
</div>

@if (Model.RecommendedJobs != null && Model.RecommendedJobs.Any())
{
    <div style="background: #FDF9F3; border-bottom: var(--border); padding: 40px 36px; border-left: 6px solid var(--pink);">
        <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 28px;">
            <div style="width: 12px; height: 12px; background: var(--pink); border: 1px solid var(--ink);"></div>
            <span style="font-size: 11px; font-weight: 800; letter-spacing: 0.18em; text-transform: uppercase; color: var(--ink);">Personalized Signals — Matched to Your Profile</span>
        </div>
        <div style="display: flex; flex-direction: column; gap: 20px;">
            @foreach (var job in Model.RecommendedJobs)
            {
                <div style="background: var(--parchment); border: var(--border); padding: 24px; box-shadow: 6px 6px 0 rgba(26,22,18,0.05); position: relative;">
                    <div style="position: absolute; top: -1px; right: 20px; background: var(--pink); border: var(--border); border-top: none; padding: 4px 12px; font-size: 9px; font-weight: 900; letter-spacing: 0.05em; text-transform: uppercase; color: var(--ink);">Top Match</div>
                    @await Html.PartialAsync("_JobCard", job, new ViewDataDictionary(ViewData) { { "IsSaved", Model.SavedJobIds.Contains(job.Id) } })
                </div>
            }
        </div>
    </div>
}

<div style="flex: 1;">
    @if (!Model.Jobs.Any())
    {
        <div style="padding: 100px 36px; text-align: center; border-bottom: var(--border);">
            <div style="font-family: var(--serif); font-size: 32px; font-weight: 900; color: rgba(26,22,18,0.2); margin-bottom: 12px;">Zero Signals</div>
            <p style="font-size: 14px; color: rgba(26,22,18,0.4);">Broaden matrix parameters to expand search coverage.</p>
        </div>
    }
    else
    {
        @foreach (var job in Model.Jobs)
        {
            <div class="job-row">
                @await Html.PartialAsync("_JobCard", job, new ViewDataDictionary(ViewData) { { "IsSaved", Model.SavedJobIds.Contains(job.Id) } })
            </div>
        }
    }
</div>

@if (Model.TotalPages > 1)
{
    <div class="pagination">
        <div style="font-size: 12px; color: rgba(26,22,18,0.5); font-weight: 500;">Page @Model.CurrentPage of @Model.TotalPages</div>
        <div style="display: flex; gap: 0;">
            <button class="page-btn" @(Model.CurrentPage <= 1 ? "disabled" : "") 
                    hx-get="/Jobs?page=@(Model.CurrentPage - 1)&query=@Model.Query&location=@Model.Location&experienceLevel=@Model.ExperienceLevel&salaryMin=@Model.SalaryMin" 
                    hx-target="#job-results"
                    style="border-right: none;">← Previous</button>
            <button class="page-btn" @(Model.CurrentPage >= Model.TotalPages ? "disabled" : "")
                    hx-get="/Jobs?page=@(Model.CurrentPage + 1)&query=@Model.Query&location=@Model.Location&experienceLevel=@Model.ExperienceLevel&salaryMin=@Model.SalaryMin" 
                    hx-target="#job-results">Next →</button>
        </div>
    </div>
}
