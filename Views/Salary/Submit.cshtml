@model Jobalatica.Models.ViewModels.SalarySubmitViewModel
@{
    ViewData["Title"] = "Contribute Salary Data";
}

<style>
    .salary-layout { display: grid; grid-template-columns: 1fr 1fr; min-height: 90vh; border-bottom: var(--border); }
    .salary-editorial { 
        border-right: var(--border); 
        background: url('/Img/salary_photo.png') center/cover no-repeat;
        padding: 72px 56px; 
        display: flex; 
        flex-direction: column; 
        justify-content: center; 
        position: relative; 
        overflow: hidden; 
    }
    .salary-editorial::before {
        content: "";
        position: absolute;
        top: 0; left: 0; right: 0; bottom: 0;
        background: linear-gradient(135deg, rgba(216,206,238,0.45) 0%, rgba(216,206,238,0.1) 100%);
        z-index: 1;
    }
    .salary-editorial > * { position: relative; z-index: 2; }

    .editorial-title { font-family: var(--serif); font-size: clamp(38px,4vw,60px); font-weight: 900; line-height: 1.05; letter-spacing: -0.03em; margin-bottom: 24px; color: var(--ink); }
    .editorial-body { font-size: 15px; font-weight: 500; line-height: 1.8; color: var(--ink); max-width: 420px; margin-bottom: 40px; }
    
    .stats-trio { display: grid; grid-template-columns: repeat(3,1fr); border: var(--border); box-shadow: var(--shadow); background: rgba(246, 241, 230, 0.7); backdrop-filter: blur(4px); }
    .trio-cell { padding: 20px 16px; border-right: var(--border); text-align: center; }
    .trio-cell:last-child { border-right: none; }
    .trio-num { font-family: var(--serif); font-size: 28px; font-weight: 900; letter-spacing: -0.04em; display: block; }
    .trio-label { font-size: 9px; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: rgba(26,22,18,0.4); display: block; margin-top: 4px; }

    .salary-form-side { padding: 56px 64px; display: flex; flex-direction: column; justify-content: center; }
    .form-card { border: var(--border); box-shadow: var(--shadow); background: var(--parchment); }
    .form-card-header { border-bottom: var(--border); padding: 20px 28px; background: var(--parchment-2); }
    .form-card-title { font-family: var(--serif); font-size: 22px; font-weight: 700; letter-spacing: -0.02em; }
    .form-card-body { padding: 28px; display: flex; flex-direction: column; gap: 20px; }

    .field-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    .field { display: flex; flex-direction: column; gap: 7px; }
    .field label { font-size: 9px; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; color: rgba(26,22,18,0.45); }
    
    .salary-input-row { display: flex; border: var(--border); }
    .salary-prefix { padding: 11px 12px; border-right: var(--border); font-size: 12px; font-weight: 600; color: rgba(26,22,18,0.5); background: var(--parchment-2); display: flex; align-items: center; }
    .salary-num { flex: 1; padding: 11px 13px; font-family: var(--sans); font-size: 13px; background: var(--parchment-2); border: none; outline: none; color: var(--ink); }
    .salary-cur { border-left: var(--border); }
    .salary-cur select { padding: 0 32px 0 12px; height: 100%; border: none; background: var(--parchment-2); }

    .slider-section { border: var(--border); padding: 20px; background: var(--parchment-2); }
    input[type="range"] { width: 100%; -webkit-appearance: none; height: 4px; background: var(--ink); outline: none; margin-bottom: 8px; }
    input[type="range"]::-webkit-slider-thumb { -webkit-appearance: none; width: 16px; height: 16px; background: var(--ink); border: 2px solid var(--parchment); box-shadow: 0 0 0 2px var(--ink); }
</style>

<div class="salary-layout">
    <div class="salary-editorial">
        <div class="win-label">
            <div class="win-dot"></div>
            Collective Intelligence
        </div>
        <h1 class="editorial-title">Help <em>build</em><br/>the market.</h1>
        <p class="editorial-body">
            Every data point you share is anonymized and aggregated. Your contribution shapes the negotiating power of the entire collective.
        </p>
        <div class="stats-trio">
            <div class="trio-cell"><span class="trio-num">1.2K</span><span class="trio-label">Data Points</span></div>
            <div class="trio-cell"><span class="trio-num">100%</span><span class="trio-label">Anonymous</span></div>
            <div class="trio-cell"><span class="trio-num">14</span><span class="trio-label">Countries</span></div>
        </div>
    </div>

    <div class="salary-form-side">
        <div class="form-card">
            <div class="form-card-header">
                <div class="form-card-title">Submit Salary Data</div>
            </div>
            <div class="form-card-body">
                <form asp-action="Submit" method="post" style="display: flex; flex-direction: column; gap: 20px;">
                    <div class="field-row">
                        <div class="field">
                            <label asp-for="JobTitle">Exact Job Title</label>
                            <input asp-for="JobTitle" placeholder="e.g. Senior Backend Engineer" />
                        </div>
                        <div class="field">
                            <label asp-for="Location">Location</label>
                            <input asp-for="Location" placeholder="e.g. Cairo, Egypt" />
                        </div>
                    </div>

                    <div class="field">
                        <label asp-for="CompanyName">Company Name</label>
                        <input asp-for="CompanyName" placeholder="e.g. Google, Stripe, or 'Stealth Startup'" />
                    </div>

                    <div class="field">
                        <label asp-for="Salary">Annual Gross Salary</label>
                        <div class="salary-input-row">
                            <span class="salary-prefix">$</span>
                            <input class="salary-num" asp-for="Salary" type="number" placeholder="60,000"/>
                            <div class="salary-cur">
                                <select asp-for="Currency">
                                    <option value="USD">USD</option>
                                    <option value="EGP">EGP</option>
                                    <option value="SAR">SAR</option>
                                    <option value="AED">AED</option>
                                </select>
                            </div>
                        </div>
                    </div>

                    <div class="slider-section">
                        <div style="display: flex; justify-content: space-between; margin-bottom: 12px;">
                            <span style="font-size: 9px; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; color: rgba(26,22,18,0.45);">Years of Experience</span>
                            <span id="sliderVal" style="font-family: var(--serif); font-size: 18px; font-weight: 900;">@Model.YearsExperience yrs</span>
                        </div>
                        <input type="range" asp-for="YearsExperience" min="0" max="20" step="1" id="expSlider" oninput="document.getElementById('sliderVal').textContent=this.value+' yrs'"/>
                    </div>

                    <div class="field">
                        <label asp-for="SkillsList">Primary Skills (comma-separated)</label>
                        <textarea asp-for="SkillsList" rows="2" placeholder="React, TypeScript, Node.js, AWS…"></textarea>
                    </div>

                    <button type="submit" class="btn btn-dark" style="width: 100%; justify-content: center; padding: 16px;">
                        Submit Market Data
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
