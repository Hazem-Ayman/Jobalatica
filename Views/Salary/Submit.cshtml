@model Jobalatica.Models.ViewModels.SalarySubmitViewModel
@{
    ViewData["Title"] = "Contribute Salary Data";
}

<div class="max-w-3xl mx-auto">
    <div class="mb-12 text-center">
        <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-4">Improve Market Transparency</h1>
        <p class="text-gray-600 dark:text-gray-400">Share your salary anonymously to help other developers know their worth. Your data is aggregated and never shown individually.</p>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="p-4 mb-8 text-sm text-green-800 rounded-2xl bg-green-50 dark:bg-gray-800 dark:text-green-400 font-bold border border-green-100 dark:border-green-900 flex items-center">
            <svg class="w-5 h-5 mr-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
            @TempData["Success"]
        </div>
    }

    <div class="bg-white dark:bg-gray-800 rounded-3xl shadow-xl border border-gray-100 dark:border-gray-700 p-8 md:p-12">
        <form asp-action="Submit" method="post" class="space-y-8">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <div>
                    <label asp-for="JobTitle" class="block mb-2 text-sm font-bold text-gray-500 uppercase tracking-wider">Exact Job Title</label>
                    <input asp-for="JobTitle" class="w-full bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-xl focus:ring-blue-500 focus:border-blue-500 p-4 dark:bg-gray-700 dark:border-gray-600 dark:text-white" placeholder="e.g. Senior Full Stack Engineer">
                    <span asp-validation-for="JobTitle" class="text-red-500 text-xs mt-1"></span>
                </div>

                <div>
                    <label asp-for="Location" class="block mb-2 text-sm font-bold text-gray-500 uppercase tracking-wider">Location (City)</label>
                    <input asp-for="Location" class="w-full bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-xl focus:ring-blue-500 focus:border-blue-500 p-4 dark:bg-gray-700 dark:border-gray-600 dark:text-white" placeholder="e.g. Cairo or Remote">
                    <span asp-validation-for="Location" class="text-red-500 text-xs mt-1"></span>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <div class="md:col-span-2">
                    <label asp-for="Salary" class="block mb-2 text-sm font-bold text-gray-500 uppercase tracking-wider">Annual Gross Salary</label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 flex items-center pl-4 pointer-events-none text-gray-500 font-bold">$</div>
                        <input asp-for="Salary" class="w-full bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-xl focus:ring-blue-500 focus:border-blue-500 p-4 pl-10 dark:bg-gray-700 dark:border-gray-600 dark:text-white" placeholder="75,000">
                    </div>
                    <span asp-validation-for="Salary" class="text-red-500 text-xs mt-1"></span>
                </div>

                <div>
                    <label asp-for="Currency" class="block mb-2 text-sm font-bold text-gray-500 uppercase tracking-wider">Currency</label>
                    <select asp-for="Currency" class="w-full bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-xl focus:ring-blue-500 focus:border-blue-500 p-4 dark:bg-gray-700 dark:border-gray-600 dark:text-white">
                        <option value="USD">USD</option>
                        <option value="EGP">EGP</option>
                        <option value="SAR">SAR</option>
                        <option value="AED">AED</option>
                        <option value="EUR">EUR</option>
                    </select>
                </div>
            </div>

            <div>
                <div class="flex justify-between items-center mb-4">
                    <label asp-for="YearsExperience" class="text-sm font-bold text-gray-500 uppercase tracking-wider">Years of Experience</label>
                    <span id="exp-value" class="bg-blue-100 text-blue-800 text-sm font-extrabold px-3 py-1 rounded-lg">0 years</span>
                </div>
                <input asp-for="YearsExperience" type="range" min="0" max="40" value="0" step="1" id="exp-slider" class="w-full h-2 bg-gray-200 rounded-lg appearance-none cursor-pointer dark:bg-gray-700">
                <div class="flex justify-between text-xs text-gray-400 mt-2">
                    <span>Entry</span>
                    <span>20 years</span>
                    <span>40+ years</span>
                </div>
            </div>

            <div>
                <label asp-for="SkillsList" class="block mb-2 text-sm font-bold text-gray-500 uppercase tracking-wider">Primary Skills (Comma separated)</label>
                <textarea asp-for="SkillsList" rows="3" class="w-full bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-xl focus:ring-blue-500 focus:border-blue-500 p-4 dark:bg-gray-700 dark:border-gray-600 dark:text-white" placeholder="e.g. C#, .NET Core, SQL Server, React"></textarea>
                <p class="mt-2 text-xs text-gray-400">Mentioning your skills helps us provide more accurate role analysis.</p>
            </div>

            <div class="pt-8 border-t border-gray-100 dark:border-gray-700 flex flex-col md:flex-row items-center justify-between gap-6">
                <p class="text-xs text-gray-500 max-w-sm italic">
                    <svg class="w-4 h-4 inline mr-1 text-gray-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd"></path></svg>
                    Your privacy is protected. Data is aggregated and used only for statistical purposes.
                </p>
                <button type="submit" class="w-full md:w-auto text-white bg-blue-700 hover:bg-blue-800 font-bold rounded-xl text-sm px-12 py-4 text-center transition-all">
                    Submit Market Data
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const slider = document.getElementById('exp-slider');
        const display = document.getElementById('exp-value');

        slider.addEventListener('input', (e) => {
            const val = e.target.value;
            display.innerText = val + (val == 1 ? ' year' : ' years');
        });

        // Initialize display
        display.innerText = slider.value + (slider.value == 1 ? ' year' : ' years');
    </script>
}
